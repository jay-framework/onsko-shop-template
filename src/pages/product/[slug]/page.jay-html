<html>
  <head>
    <script type="application/jay-headless"
            plugin="@jay-framework/wix-stores"
            contract="product-page"
            key="productPage"
    ></script>
    <script type="application/jay-headless"
            plugin="@jay-framework/wix-stores"
            contract="category-products"
    ></script>
    <title>{productPage.productName} | Onsko</title>
    <meta name="description" content="Shop {productPage.productName} at Onsko. Clean beauty products for everyone.">
    <script type="application/jay-headfull" src="../../../components/site-header/site-header" names="SiteHeader" contract="../../../components/site-header/site-header.jay-contract"></script>
    <script type="application/jay-headfull" src="../../../components/site-footer/site-footer" names="SiteFooter" contract="../../../components/site-footer/site-footer.jay-contract"></script>
    <script type="application/jay-data">
      data:
    </script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,200;0,400;0,600;0,700;1,400;1,700&display=swap">
    <link rel="stylesheet" href="../../../styles/onsko-theme.css" />
    <style>
      /* =====================================================
         ONSKO PRODUCT DETAIL PAGE - TWO COLUMN LAYOUT
         Gallery left (~55%), details right (~45%)
         ===================================================== */

      .product-detail-page {
        min-height: 100vh;
      }

      .product-container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 120px var(--page-padding) 0;
      }

      /* Two Column Layout */
      .product-layout {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 64px;
        align-items: start;
      }

      /* Gallery */
      .product-gallery {
        position: sticky;
        top: 80px;
      }

      .product-main-image {
        aspect-ratio: 1;
        overflow: hidden;
        background: var(--bg-product-image);
        border-radius: var(--radius-xl);
      }

      .product-main-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* Details */
      .product-details {
        padding-top: 0;
      }

      .product-details h1 {
        font-size: clamp(28px, 4vw, 40px);
        font-weight: 600;
        line-height: 1.15;
        margin-bottom: 12px;
        letter-spacing: -0.01em;
      }

      .product-pricing {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 16px;
      }

      .product-pricing .current-price {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-primary);
      }

      .product-pricing .strikethrough-price {
        font-size: 18px;
        color: var(--text-muted);
        text-decoration: line-through;
      }

      .product-description {
        font-size: 15px;
        line-height: 1.7;
        color: var(--text-secondary);
        margin-bottom: 28px;
      }

      /* Options */
      .product-options {
        margin-bottom: 24px;
      }

      .option-group {
        margin-bottom: 20px;
      }

      .option-choices {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      /* Modifiers */
      .product-modifiers {
        margin-bottom: 24px;
      }

      .modifier-group {
        margin-bottom: 20px;
      }

      /* Quantity */
      .quantity-section {
        margin-bottom: 24px;
      }

      .quantity-input::-webkit-inner-spin-button,
      .quantity-input::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
      }

      .quantity-input {
        -moz-appearance: textfield;
        appearance: textfield;
      }

      /* Action Buttons */
      .product-actions {
        display: flex;
        gap: 12px;
        margin-bottom: 32px;
      }

      .product-actions .btn {
        flex: 1;
      }

      /* Info Sections Accordion */
      .info-sections {
        border-top: 1px solid var(--border);
      }

      .info-section {
        border-bottom: 1px solid var(--border);
      }

      .info-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 0;
        cursor: pointer;
      }

      .info-section-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-primary);
      }

      .info-section-toggle {
        font-size: 20px;
        color: var(--text-muted);
        line-height: 1;
      }

      .info-section-content {
        padding: 0 0 18px;
        font-size: 14px;
        line-height: 1.7;
        color: var(--text-secondary);
      }

      /* Best Sellers Section */
      .related-section {
        padding-top: 40px;
      }

      /* Best Sellers Cards (match homepage) */
      .related-section .product-card {
        border-radius: 0;
        background: transparent;
        box-shadow: none;
      }

      .related-section .product-card:hover {
        box-shadow: none;
        transform: none;
      }

      .related-section .product-card-image {
        aspect-ratio: 4 / 5;
        border-radius: 20px;
      }

      .related-section .product-card-content {
        padding: 12px 4px;
        background: transparent;
      }

      .best-seller-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        z-index: 2;
        background: #bdd8f1;
        color: var(--text-primary);
        font-family: poppins-extralight, poppins, sans-serif;
        font-size: 12px;
        font-weight: 400;
        padding: 3px 10px;
        border-radius: 2px;
        letter-spacing: 0.02em;
      }

      /* Responsive */
      @media (max-width: 1024px) {
        .product-layout {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .product-gallery {
          position: static;
        }
      }

      @media (max-width: 600px) {
        .product-container {
          padding: 32px var(--page-padding) 60px;
        }

        .product-actions {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <main class="product-detail-page">
      <!-- Site Header -->
      <jay:SiteHeader />

      <!-- Product Detail -->
      <div class="product-container">
        <div class="product-layout">
          <!-- Gallery (left ~55%) -->
          <div class="product-gallery">
            <div class="product-main-image">
              <img src="{productPage.mediaGallery.selectedMedia.url}/v1/fill/w_800,h_800/file.webp" srcset="{productPage.mediaGallery.selectedMedia.url}/v1/fill/w_400%2Ch_400/file.webp 400w, {productPage.mediaGallery.selectedMedia.url}/v1/fill/w_600%2Ch_600/file.webp 600w, {productPage.mediaGallery.selectedMedia.url}/v1/fill/w_800%2Ch_800/file.webp 800w" sizes="(max-width: 768px) 100vw, 50vw" alt="{productPage.productName}" loading="eager" fetchpriority="high" width="800" height="800" />
            </div>
          </div>

          <!-- Details (right ~45%) -->
          <div class="product-details">
            <h1>{productPage.productName}</h1>

            <div class="product-pricing">
              <span class="current-price">{productPage.price}</span>
              <span class="strikethrough-price" if="productPage.strikethroughPrice">{productPage.strikethroughPrice}</span>
            </div>

            <div class="product-description">{productPage.description}</div>

            <!-- Options -->
            <div class="product-options" if="productPage.options">
              <div class="option-group" forEach="productPage.options" trackBy="_id">
                <label class="option-label">{name}</label>

                <!-- Text Choices -->
                <select class="select"
                        if="optionRenderType == TEXT_CHOICES"
                        ref="productPage.options.textChoice"
                        aria-label="{name}">
                  <option forEach="choices" trackBy="choiceId" value="{choiceId}">{name}</option>
                </select>

                <!-- Color Swatch Choices -->
                <div class="option-choices" if="optionRenderType == COLOR_SWATCH_CHOICES">
                  <button class="choice-btn color-swatch {isSelected ? selected} {!inStock ? out-of-stock}"
                          style="background-color: {colorCode}"
                          forEach="choices"
                          trackBy="choiceId"
                          ref="productPage.options.choices.choiceButton"
                          title="{name}"
                          aria-label="{name}">
                  </button>
                </div>
              </div>
            </div>

            <!-- Modifiers -->
            <div class="product-modifiers" if="productPage.modifiers">
              <div class="modifier-group" forEach="productPage.modifiers" trackBy="_id">
                <label class="option-label">{name}</label>

                <select class="select"
                        if="modifierType == TEXT_CHOICES"
                        ref="productPage.modifiers.textModifier"
                        aria-label="{name}">
                  <option forEach="choices" trackBy="choiceId" value="{choiceId}">{name}</option>
                </select>

                <div class="option-choices" if="modifierType == COLOR_SWATCH_CHOICES">
                  <button class="choice-btn color-swatch {isSelected ? selected}"
                          style="background-color: {colorCode}"
                          forEach="choices"
                          trackBy="choiceId"
                          ref="choiceButton"
                          title="{name}"
                          aria-label="{name}">
                  </button>
                </div>

                <input class="input"
                       type="text"
                       if="modifierType == FREE_TEXT"
                       ref="productPage.modifiers.textInput"
                       placeholder="Enter your text"
                       maxlength="{textInputLength}"
                       aria-label="{name}" />
              </div>
            </div>

            <!-- Quantity -->
            <div class="quantity-section">
              <label class="option-label">Quantity</label>
              <div class="quantity-controls">
                <button class="quantity-btn" ref="productPage.quantity.decrementButton" aria-label="Decrease quantity">−</button>
                <input class="quantity-input"
                       type="number"
                       value="{productPage.quantity.quantity}"
                       ref="productPage.quantity.quantity"
                       min="1"
                       aria-label="Quantity" />
                <button class="quantity-btn" ref="productPage.quantity.incrementButton" aria-label="Increase quantity">+</button>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="product-actions">
              <button class="btn btn-primary" ref="productPage.addToCartButton" aria-label="Add to cart">add to cart</button>
              <button class="btn btn-secondary" ref="productPage.buyNowButton" aria-label="Buy now">buy now</button>
            </div>

            <!-- Info Sections Accordion -->
            <div class="info-sections" if="productPage.infoSections">
              <div class="info-section" forEach="productPage.infoSections" trackBy="_id">
                <div class="info-section-header">
                  <h2 class="info-section-title">{title}</h2>
                  <span class="info-section-toggle">+</span>
                </div>
                <div class="info-section-content">{plainDescription}</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Related Products -->
      <jay:category-products productId="{productPage._id}" categorySlug="best-sellers" limit="4">
        <section class="related-section" if="hasProducts">
          <h2 class="section-title">best sellers</h2>
          <div class="related-grid">
            <a href="{productUrl}" class="product-card" forEach="products" trackBy="_id" ref="products.productLink">
              <div class="product-card-image">
                <span class="best-seller-badge">best seller</span>
                <img src="{thumbnail.url}/v1/fill/w_600,h_600/file.webp" srcset="{thumbnail.url}/v1/fill/w_300%2Ch_300/file.webp 300w, {thumbnail.url}/v1/fill/w_400%2Ch_400/file.webp 400w, {thumbnail.url}/v1/fill/w_600%2Ch_600/file.webp 600w" sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 25vw" alt="{thumbnail.altText}" loading="lazy" width="600" height="600" />
              </div>
              <div class="product-card-content">
                <h3 class="product-card-name">{name}</h3>
                <div class="product-card-price"><span class="current-price">{price}</span></div>
              </div>
            </a>
          </div>
        </section>
      </jay:category-products>

      <!-- Site Footer -->
      <jay:SiteFooter />
    </main>
  </body>
</html>
