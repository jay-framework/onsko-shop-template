<html>
  <head>
    <title>Onsko | Clean Beauty Products</title>
    <meta name="description" content="Discover clean beauty products for face, body, and hair. Beauty that reflects your spirit.">
    <script type="application/jay-headless" plugin="@jay-framework/wix-cart" contract="cart-indicator"></script>
    <script type="application/jay-headless" plugin="@jay-framework/wix-stores" contract="category-products"></script>
    <script type="application/jay-headfull" src="../components/site-footer/site-footer" names="SiteFooter" contract="../components/site-footer/site-footer.jay-contract"></script>
    <script type="application/jay-data" contract="./page.jay-contract"></script>
    <link rel="stylesheet" href="../styles/onsko-theme.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@200;600&display=swap" />
    <style>
      /* ── Body matches best-sellers fold ── */
      body { background: var(--bg-primary); }

      @keyframes header-float-in {
        0% {
          opacity: 0;
          transform: translateY(-30px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ── Homepage Unique Header ── */
      .home-header {
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 50px 50px 0;
        margin-bottom: -97px;
        transition: transform 0.5s ease, opacity 0.5s ease;
        animation: header-float-in 0.7s ease-out backwards;
      }

      .home-header.header-hidden {
        transform: translateY(-110%);
        opacity: 0;
        transition: transform 0.5s ease 0.2s, opacity 0.5s ease 0.5s;
      }

      .home-header-bar {
        background: #ffffff;
        border-radius: var(--radius-full);
        box-shadow: var(--shadow-md);
        height: 47px;
      }

      .home-header-inner {
        max-width: var(--container-max);
        margin: 0 auto;
        display: flex;
        align-items: center;
        height: 100%;
        padding: 0 24px;
        gap: 32px;
      }

      .home-logo {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: 0.02em;
        white-space: nowrap;
      }

      .home-logo-icon {
        color: var(--accent);
        font-size: 24px;
      }

      .home-nav {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .home-nav a {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        padding: 4px 0;
        transition: color var(--transition-fast);
      }

      .home-nav a:hover {
        color: var(--text-primary);
      }

      .home-header-actions {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
        color: var(--text-primary);
      }

      .home-action-text {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        transition: color var(--transition-fast);
        white-space: nowrap;
      }

      .home-action-text:hover {
        color: var(--text-primary);
      }

      .home-action-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        transition: color var(--transition-fast);
      }

      .home-action-icon:hover {
        color: var(--text-primary);
      }

      .home-cart-indicator {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      .home-cart-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 24px;
        height: 24px;
        padding: 0 6px;
        background: var(--success);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        border-radius: var(--radius-full);
      }

      .home-cart-indicator.just-added {
        animation: cart-flash 0.4s ease;
      }

      .home-search-label {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        white-space: nowrap;
      }

      @media (max-width: 768px) {
        .home-header { padding: 24px 16px 0; margin-bottom: -71px; }
        .home-header-inner { padding: 0 16px; gap: 16px; }
        .home-nav { gap: 14px; }
        .home-header-actions { gap: 12px; }
        .home-search-label { display: none; }
        .home-action-text { display: none; }
      }

      @media (max-width: 600px) {
        .home-header-inner { flex-wrap: wrap; gap: 10px; }
        .home-nav a { font-size: 13px; }
      }

      /* ── Hero Section ── */
      .hero {
        position: relative;
        aspect-ratio: 19 / 10;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        text-align: left;
        background: linear-gradient(135deg, #e87a4a 0%, #d4643a 30%, #3d7a5e 70%, #2d5d45 100%);
        color: #fff;
        overflow: hidden;
        padding: 60px 40px 40px;
        margin: 25px;
        border-radius: 20px;
      }

      @keyframes hero-float-in {
        0% {
          opacity: 0;
          transform: translateY(30px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .hero-bg-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        animation: hero-float-in 0.7s ease-out both;
      }

      @keyframes hero-slide-up {
        0% {
          transform: translateY(100%);
        }
        100% {
          transform: translateY(0);
        }
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 520px;
      }

      .hero-line-clip {
        overflow: hidden;
      }

      .hero-line-clip > * {
        animation: hero-slide-up 0.8s ease-out both;
      }

      .hero-line-clip:nth-child(2) > * {
        animation-delay: 0.15s;
      }

      .hero-line-clip:nth-child(3) > * {
        animation-delay: 0.3s;
      }

      .hero h1 {
        font-size: clamp(48px, 10vw, 96px);
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0;
        letter-spacing: -0.02em;
      }

      .hero p {
        font-family: var(--font-primary);
        font-size: clamp(18px, 2.5vw, 24px);
        font-style: normal;
        opacity: 0.95;
        margin-bottom: 15px;
        font-weight: 400;
        line-height: 1.3;
      }

      .hero .btn-cta {
        padding: 10px 64px;
        font-size: 18px;
        background: transparent;
        color: #fff;
        border: 2px solid rgba(255, 255, 255, 0.8);
        border-radius: var(--radius-lg);
      }

      .hero .btn-cta:hover {
        background: rgba(255, 255, 255, 0.15);
        border-color: #fff;
      }

      .best-sellers {
        background: var(--bg-primary);
        padding: 64px 0;
        margin: 0 25px;
        position: sticky;
        top: 0;
        z-index: 1;
      }

      .best-sellers-inner {
        width: 100%;
      }

      /* ── Scroll-triggered animation ── */
      .scroll-animate {
        opacity: 0;
        transform: translateY(30px);
        transition: none;
      }

      .scroll-animate.in-view {
        animation: hero-float-in 0.7s ease-out both;
        animation-delay: var(--scroll-delay, 0s);
      }

      .best-sellers-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
      }

      .best-sellers-header .section-title {
        font-size: clamp(32px, 4vw, 42px);
        font-weight: 700;
      }

      .view-more-link {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-primary);
        padding: 10px 28px;
        border: 2px solid var(--border, #d4d4d4);
        border-radius: 8px;
        transition: background-color 0.2s ease, border-color 0.2s ease;
      }

      .view-more-link:hover {
        background-color: var(--bg-secondary, #f5f5f5);
        border-color: var(--text-primary);
      }

      .best-sellers-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
      }

      .best-sellers .product-card {
        border-radius: 0;
        background: transparent;
        box-shadow: none;
      }

      .best-sellers .product-card:hover {
        box-shadow: none;
        transform: none;
      }

      .best-sellers .product-card-image {
        aspect-ratio: 4 / 5;
        border-radius: 20px;
      }

      .best-sellers .product-card-content {
        padding: 12px 4px;
        background: transparent;
      }

      .best-seller-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        z-index: 2;
        background: #bdd8f1;
        color: var(--text-primary);
        font-size: 12px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 2px;
        letter-spacing: 0.02em;
      }

      /* ── Full-width Banner (between best sellers & roller) ── */
      .fold3-banner-wrapper {
        position: relative;
        z-index: 2;
        margin: 0 25px;
        padding: 25px 0;
        background: var(--bg-primary);
      }

      .fold3-banner {
        position: relative;
        aspect-ratio: 19 / 10;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        overflow: hidden;
        border-radius: 20px 20px 0 0;
      }

      .fold3-banner-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
      }

      .fold3-banner-content {
        position: relative;
        z-index: 2;
        padding: 60px 40px 40px;
        max-width: 520px;
      }

      .fold3-banner-content h2 {
        font-family: var(--font-primary);
        font-size: clamp(32px, 5vw, 48px);
        font-weight: 700;
        line-height: 1.1;
        color: #2d3436;
        margin-bottom: 8px;
        letter-spacing: -0.02em;
      }

      .fold3-banner-content p {
        font-family: var(--font-primary);
        font-size: clamp(16px, 2vw, 20px);
        font-weight: 400;
        line-height: 1.3;
        color: #2d3436;
        margin-bottom: 20px;
      }

      .fold3-banner-content .btn-banner {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 36px;
        font-size: 16px;
        font-weight: 500;
        color: #2d3436;
        background: transparent;
        border: 2px solid #2d3436;
        border-radius: var(--radius-lg);
        text-transform: lowercase;
        letter-spacing: 0.02em;
        transition: background-color 0.2s ease, border-color 0.2s ease;
      }

      .fold3-banner-content .btn-banner:hover {
        background: rgba(0, 0, 0, 0.08);
        border-color: #2d3436;
      }

      @media (max-width: 768px) {
        .fold3-banner-content {
          padding: 48px 32px;
        }
      }

      @media (max-width: 480px) {
        .fold3-banner-content {
          padding: 32px 24px;
          max-width: 100%;
        }
      }

      .shipping-banner {
        background: #d5e955;
        border-radius: 0 0 20px 20px;
        padding: 16px 0;
        overflow: hidden;
      }

      .marquee {
        display: flex;
        gap: 48px;
        animation: marquee 20s linear infinite;
        white-space: nowrap;
      }

      .marquee span {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      .shop-by-category {
        position: relative;
        z-index: 2;
        background: var(--bg-primary);
        padding: 40px 25px 80px;
      }

      .shop-by-category-inner {
        width: 100%;
      }

      .shop-by-category-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
      }

      .shop-by-category h2 {
        text-align: left;
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 0;
      }

      .shop-by-category .btn-shop-now {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 36px;
        font-size: 16px;
        font-weight: 500;
        color: #2d3436;
        background: transparent;
        border: 2px solid #2d3436;
        border-radius: var(--radius-lg);
        text-transform: lowercase;
        letter-spacing: 0.02em;
        transition: background-color 0.2s ease, border-color 0.2s ease;
      }

      .shop-by-category .btn-shop-now:hover {
        background: rgba(0, 0, 0, 0.08);
        border-color: #2d3436;
      }

      .category-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .category-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        border-radius: var(--radius-xl);
        border: none;
        background: #e0ddd9;
        padding: 29px;
        gap: 12px;
        transition: transform var(--transition-base), background-color 0.3s ease;
      }

      .category-card:hover { transform: translateY(-4px); }

      .category-card:nth-child(1):hover { background-color: #bdd8f1; }
      .category-card:nth-child(2):hover { background-color: #e8874a; }
      .category-card:nth-child(3):hover { background-color: #d5e955; }

      .category-card img {
        width: 100%;
        aspect-ratio: 3/4;
        object-fit: cover;
        border-radius: calc(var(--radius-xl) - 6px);
      }

      .category-card-label {
        display: inline-block;
        padding: 10px 36px;
        border: 2px solid #2d3436;
        border-radius: var(--radius-lg);
        font-size: 18px;
        font-weight: 600;
        text-align: center;
        color: #2d3436;
        background: transparent;
        margin-bottom: 4px;
      }

      .our-story-wrapper {
        position: relative;
        z-index: 1;
        margin: 0 25px 100px 25px;
        background: var(--bg-primary);
        height: 2000px;
      }

      /* Layer 1: background (bottom) */
      .our-story-background {
        position: sticky;
        top: 13vh;
        background: #a0c8ff;
        text-align: center;
        padding: 100px var(--page-padding);
        border-radius: 20px;
        z-index: 1;
        height: 40vw;
        color: transparent;
      }

      /* Layer 3: text (top) */
      .our-story-text {
        position: sticky;
        top: 13vh;
        z-index: 3;
        height: 0;
        overflow: visible;
        pointer-events: none;
        padding-bottom: 500px;
        margin-top: calc(-52vh)
      }

      .our-story-text-content {
        text-align: center;
        color: #2d4d3f;
        padding: clamp(50px, 4vw, 100px) var(--page-padding);
        pointer-events: auto;
        width: 78%;
        margin: auto;
      }

      .our-story-text-content h2 {
          font-family: 'Poppins', sans-serif;
          font-size: max(12px, calc(42 * clamp(0px, 100 * 1cqw * 1, min(9999px, 9999px)) / 1280));
          font-weight: 600;
          text-transform: lowercase;
          letter-spacing: 0.02em;
          margin-bottom: 16px;
          color: #2d4d3f;
      }

      .our-story-text-content p {
          font-family: 'kepler-w03-light-scd-cp', serif;
          font-size: clamp(36px, 4vw, 58px);
          font-weight: 300;
          font-style: normal;
          line-height: 1.3;
          margin: 0 auto 16px;
          color: #2d4d3f;
      }

      .our-story-text-content .tagline {
          font-family: 'Poppins', sans-serif;
          font-size: 14px;
          font-weight: 200;
          font-style: normal;
          opacity: 1;
          letter-spacing: 0.05em;
          color: #2d4d3f;
      }

      /* Layer 2: images (middle) */
      .our-story-float-right {
        position: sticky;
        top: 35vh;
        height: 0;
        z-index: 2;
        pointer-events: none;
        margin-top: 300px;
        margin-bottom: 400px;
      }

      .our-story-float-left {
        position: sticky;
        top: 25vh;
        height: 0;
        z-index: 2;
        pointer-events: none;
        margin-top: 700px;
        margin-bottom: 500px;
      }

      .our-story-img-left,
      .our-story-img-right {
        position: absolute;
        pointer-events: auto;
      }

      .our-story-img-left {
        left: 60px;
        top: 30px;
        width: clamp(100px, 15vw, 350px);
        object-fit: contain;
        animation: float-gentle 6s ease-in-out infinite;
      }

      @keyframes float-gentle {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
      }

      .our-story-img-right {
        right: 80px;
        top: 40px;
        width: clamp(80px, 15vw, 450px);
        object-fit: contain;
        animation: float-complex 23s ease-in-out infinite;
      }

      @keyframes float-complex {
        0% { transform: translateY(0); }
        13% { transform: translateY(-20px); }
        26% { transform: translateY(0); }
        39% { transform: translateY(-8px); }
        52% { transform: translateY(0); }
        74% { transform: translateY(0); }
        87% { transform: translateY(-12px); }
        100% { transform: translateY(0); }
      }

      @media (max-width: 768px) {
        .our-story-wrapper {
          padding-bottom: 600px;
        }
        .our-story-float-right {
          margin-top: 200px;
        }
        .our-story-float-left {
          margin-top: 400px;
        }
        .our-story-img-left {
          left: 10px;
          top: 20px;
        }
        .our-story-img-right {
          right: 10px;
          top: 30px;
        }
      }

      .instagram-section {
        position: relative;
        z-index: 2;
        background: var(--bg-footer);
        color: #fff;
        text-align: center;
        padding: 64px var(--page-padding);
      }

      .instagram-section h2 {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 8px;
      }

      .instagram-section p {
        font-size: 14px;
        opacity: 0.6;
        margin-bottom: 32px;
      }

      .instagram-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 8px;
        max-width: 1000px;
        margin: 0 auto;
      }

      .instagram-grid .ig-image {
        aspect-ratio: 1;
        background: rgba(255,255,255,0.1);
        border-radius: var(--radius-md);
        overflow: hidden;
      }

      .instagram-grid .ig-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      @media (max-width: 1024px) {
        .best-sellers-grid { grid-template-columns: repeat(2, 1fr); }
      }

      @media (max-width: 768px) {
        .best-sellers { padding: 48px var(--page-padding); }
        .best-sellers-header { margin-bottom: 24px; }
        .best-sellers-header .section-title { font-size: clamp(26px, 5vw, 32px); }
        .view-more-link { padding: 8px 20px; font-size: 14px; }
        .best-sellers-grid { gap: 16px; }
        .category-cards { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
        .instagram-grid { grid-template-columns: repeat(3, 1fr); }
      }

      @media (max-width: 600px) {
        .best-sellers-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 16px;
        }
        .view-more-link { align-self: flex-start; }
        .best-sellers-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
        .instagram-grid { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </head>
  <body>
    <main class="home-page">
      <header class="home-header {headerHidden ? header-hidden}">
        <div class="home-header-bar">
          <div class="home-header-inner">
            <a href="/" class="home-logo"><span class="home-logo-icon">✻</span> onsko</a>
            <nav class="home-nav">
              <a href="/">home</a>
              <a href="/products">shop</a>
              <a href="#">about</a>
              <a href="#">blog</a>
            </nav>
            <div class="home-header-actions">
              <a href="#" class="home-action-text">log in</a>
              <button class="home-action-icon" aria-label="Wishlist">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
              <jay:cart-indicator>
                <a href="/cart" class="home-cart-indicator {hasItems ? has-items} {isLoading ? is-loading} {justAdded ? just-added}" ref="cartLink">
                  <span class="home-cart-badge">{itemCount}</span>
                </a>
              </jay:cart-indicator>
              <span class="home-search-label">Search</span>
              <button class="home-action-icon" aria-label="Search">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
              </button>
            </div>
          </div>
        </div>
      </header>

      <section class="hero">
        <img class="hero-bg-image" src="https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_1920,h_1080/file.webp" srcset="https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_640%2Ch_360/file.webp 640w, https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_1200%2Ch_675/file.webp 1200w, https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_1920%2Ch_1080/file.webp 1920w" sizes="100vw" alt="Onsko beauty products" loading="eager" width="1920" height="1080" fetchpriority="high" />
        <div class="hero-content">
          <div class="hero-line-clip"><h1>shine on</h1></div>
          <div class="hero-line-clip"><p>beauty that reflects your spirit</p></div>
          <div class="hero-line-clip"><a href="/products" class="btn btn-cta btn-lg">shop now</a></div>
        </div>
      </section>

      <jay:category-products categorySlug="best-sellers" limit="4">
        <section class="best-sellers">
          <div class="best-sellers-inner">
            <div class="best-sellers-header scroll-animate">
              <h2 class="section-title">best sellers</h2>
              <a href="/products/best-sellers" class="view-more-link">view more</a>
            </div>
            <div class="best-sellers-grid scroll-animate" style="--scroll-delay: 0.15s">
              <a href="{productUrl}" class="product-card" forEach="products" trackBy="_id">
                <div class="product-card-image">
                  <span class="best-seller-badge">best seller</span>
                  <img src="{thumbnail.url}/v1/fill/w_600,h_600/file.webp" srcset="{thumbnail.url}/v1/fill/w_300%2Ch_300/file.webp 300w, {thumbnail.url}/v1/fill/w_400%2Ch_400/file.webp 400w, {thumbnail.url}/v1/fill/w_600%2Ch_600/file.webp 600w" sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 25vw" alt="{thumbnail.altText}" loading="lazy" width="600" height="600" />
                </div>
                <div class="product-card-content">
                  <h3 class="product-card-name">{name}</h3>
                  <div class="product-card-price"><span class="current-price">{price}</span></div>
                </div>
              </a>
            </div>
          </div>
        </section>
      </jay:category-products>

      <div class="fold3-banner-wrapper">
        <section class="fold3-banner scroll-animate">
          <img class="fold3-banner-bg" src="https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0,y_514,w_2688,h_1278/fill/w_1437,h_683,fp_0.50_0.50,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/fold3_banner.jpg" srcset="https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0%2Cy_514%2Cw_2688%2Ch_1278/fill/w_640%2Ch_304%2Cfp_0.50_0.50%2Cq_85%2Cusm_0.66_1.00_0.01%2Cenc_avif%2Cquality_auto/fold3_banner.jpg 640w, https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0%2Cy_514%2Cw_2688%2Ch_1278/fill/w_1200%2Ch_570%2Cfp_0.50_0.50%2Cq_85%2Cusm_0.66_1.00_0.01%2Cenc_avif%2Cquality_auto/fold3_banner.jpg 1200w, https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0%2Cy_514%2Cw_2688%2Ch_1278/fill/w_1437%2Ch_683%2Cfp_0.50_0.50%2Cq_85%2Cusm_0.66_1.00_0.01%2Cenc_avif%2Cquality_auto/fold3_banner.jpg 1437w" sizes="100vw" alt="Onsko new arrivals banner" loading="lazy" width="1437" height="683" />
          <div class="fold3-banner-content">
            <h2>effortless beauty, timeless charm.</h2>
            <p>new arrivals now in stock</p>
            <a href="/products" class="btn-banner">shop now</a>
          </div>
        </section>
        <div class="shipping-banner">
          <div class="marquee">
            <span>✻ free shipping on orders over $50</span>
            <span>✻ free shipping on orders over $50</span>
            <span>✻ free shipping on orders over $50</span>
            <span>✻ free shipping on orders over $50</span>
            <span>✻ free shipping on orders over $50</span>
            <span>✻ free shipping on orders over $50</span>
            <span>✻ free shipping on orders over $50</span>
            <span>✻ free shipping on orders over $50</span>
          </div>
        </div>
      </div>

      <section class="shop-by-category">
        <div class="shop-by-category-inner">
          <div class="shop-by-category-header">
            <h2>shop by category</h2>
            <a href="/products" class="btn-shop-now">shop now</a>
          </div>
          <div class="category-cards">
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_600,h_800/file.webp" srcset="https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_300%2Ch_400/file.webp 300w, https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_400%2Ch_533/file.webp 400w, https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_600%2Ch_800/file.webp 600w" sizes="(max-width: 768px) 100vw, 33vw" alt="Face products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">face</span>
            </a>
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_600,h_800/file.webp" srcset="https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_300%2Ch_400/file.webp 300w, https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_400%2Ch_533/file.webp 400w, https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_600%2Ch_800/file.webp 600w" sizes="(max-width: 768px) 100vw, 33vw" alt="Body products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">body</span>
            </a>
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_600,h_800/file.webp" srcset="https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_300%2Ch_400/file.webp 300w, https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_400%2Ch_533/file.webp 400w, https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_600%2Ch_800/file.webp 600w" sizes="(max-width: 768px) 100vw, 33vw" alt="Hair products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">hair</span>
            </a>
          </div>
        </div>
      </section>

      <div class="our-story-wrapper">
        <section class="our-story-background">
        </section>
        <div class="our-story-text">
          <div class="our-story-text-content">
            <h2>our story</h2>
            <p>born from a passion for beauty rituals, we celebrate individuality and bring radiant confidence to everyone</p>
            <p class="tagline">for every body, anywhere</p>
          </div>
        </div>
        <div class="our-story-float-right">
          <img class="our-story-img-right" src="https://static.wixstatic.com/media/c569b3_1fc3ec35a43b4a83a87e492e4c7165e2~mv2.png/v1/fill/w_300,h_500/file.png" srcset="https://static.wixstatic.com/media/c569b3_1fc3ec35a43b4a83a87e492e4c7165e2~mv2.png/v1/fill/w_150%2Ch_250/file.png 150w, https://static.wixstatic.com/media/c569b3_1fc3ec35a43b4a83a87e492e4c7165e2~mv2.png/v1/fill/w_300%2Ch_500/file.png 300w" sizes="12vw" alt="Onsko beauty product" loading="lazy" width="300" height="500" />
        </div>
        <div class="our-story-float-left">
          <img class="our-story-img-left" src="https://static.wixstatic.com/media/c569b3_4692c37200824c34914df0c51b8644a7~mv2.png/v1/fill/w_400,h_400/file.png" srcset="https://static.wixstatic.com/media/c569b3_4692c37200824c34914df0c51b8644a7~mv2.png/v1/fill/w_200%2Ch_200/file.png 200w, https://static.wixstatic.com/media/c569b3_4692c37200824c34914df0c51b8644a7~mv2.png/v1/fill/w_400%2Ch_400/file.png 400w" sizes="15vw" alt="Onsko beauty highlight" loading="lazy" width="400" height="400" />
        </div>
      </div>

      <section class="instagram-section">
        <h2>Follow Us on Instagram</h2>
        <p>#onsko_beauty</p>
        <div class="instagram-grid">
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_a9c56931a8584d80aa7b1fa26d3b6fab~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_1bd7d185cb8a43e380138168bb3fb7c4~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_5c2838e71e5b4d1697fc1ed7cfd8e534~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_888ea433600044d0bb78c88db94f532b~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_a3d6d1e4a8fa48f899460c35095b7524~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_a819ead9b3b04405aa30d59dc840b5d0~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_d932ea27531f42dbb91ab57d9ff68687~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_c8bfc03eaabc4ce8bc38d5e558f8f712~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_8bf48c1f406f46a4bd02629af619b3c7~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_07c53dc6d5644e7dbd2dfc732ea52d1e~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
        </div>
      </section>

      <jay:SiteFooter />
    </main>
  </body>
</html>
