<html>
  <head>
    <title>Onsko | Clean Beauty Products</title>
    <meta name="description" content="Discover clean beauty products for face, body, and hair. Beauty that reflects your spirit.">
    <script type="application/jay-headless" plugin="@jay-framework/wix-cart" contract="cart-indicator"></script>
    <script type="application/jay-headless" plugin="@jay-framework/wix-members" contract="login-indicator"></script>
    <script type="application/jay-headless" plugin="@jay-framework/wix-stores" contract="category-products"></script>

    <script type="application/jay-headfull" src="../components/site-footer/site-footer" names="SiteFooter" contract="../components/site-footer/site-footer.jay-contract"></script>
    <script type="application/jay-data" contract="./page.jay-contract"></script>
    <link rel="stylesheet" href="../styles/onsko-theme.css" />
    <style>
      /* ── Body matches best-sellers fold ── */
      body { background: var(--bg-primary); }

      @keyframes header-float-in {
        0% {
          opacity: 0;
          transform: translateY(-30px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ── Homepage Unique Header ── */
      .home-header {
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 50px 50px 0;
        margin-bottom: -97px;
        /* Hidden until JS evaluates scroll position; match animation start */
        opacity: 0;
        transform: translateY(-30px);
      }

      /* Initial load: single fly-in + fade animation */
      .home-header.header-ready:not(.header-hidden):not(.header-has-scrolled) {
        animation: header-float-in 0.7s ease-out both;
      }

      /* After scroll: re-show with fade only (transform snaps to 0) */
      .home-header.header-ready:not(.header-hidden).header-has-scrolled {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.5s ease;
      }

      .home-header.header-hidden {
        transform: translateY(-110%);
        opacity: 0;
        transition: transform 0.5s ease 0.2s, opacity 0.5s ease 0.5s;
        animation: none;
      }

      .home-header-bar {
        background: #ffffff;
        border-radius: var(--radius-full);
        box-shadow: var(--shadow-md);
        height: 47px;
      }

      .home-header-inner {
        margin: 0 auto;
        display: flex;
        align-items: center;
        height: 100%;
        padding: 0 24px;
        gap: 32px;
      }

      .home-logo {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: 'Poppins', sans-serif;
        font-size: 32px;
        font-weight: 600;
        color: rgb(45, 81, 67);
        letter-spacing: -0.96px;
        white-space: nowrap;
      }

      .home-logo-icon {
        display: flex;
        align-items: center;
        color: rgb(45, 81, 67);
      }

      .home-logo-icon svg {
        width: 24px;
        height: 24px;
      }

      .home-nav {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .home-nav a {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 500;
        color: #2D5143;
        padding: 4px 0;
        transition: color var(--transition-fast);
      }

      .home-nav a.active {
        color: #AE3A00;
      }

      .home-nav a:hover {
        color: var(--text-primary);
      }

      .home-header-actions {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
        color: var(--text-primary);
      }

      .home-action-text {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 500;
        color: var(--text-secondary);
        transition: color var(--transition-fast);
        white-space: nowrap;
      }

      .home-action-text:hover {
        color: var(--text-primary);
      }

      .home-login-btn {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
      }

      .home-action-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        transition: color var(--transition-fast);
      }

      .home-action-icon:hover {
        color: var(--text-primary);
      }

      .home-cart-indicator {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      .home-cart-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 24px;
        height: 24px;
        padding: 0 6px;
        background: var(--success);
        color: #fff;
        font-family: 'Poppins', sans-serif;
        font-size: 12px;
        font-weight: 700;
        border-radius: var(--radius-full);
      }

      .home-cart-indicator.just-added {
        animation: cart-flash 0.4s ease;
      }

      .home-search-label {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 500;
        color: var(--text-secondary);
        white-space: nowrap;
      }

      /* ── Hamburger Button ── */
      .hamburger-btn {
        display: none;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        color: #2D5143;
      }
      .hamburger-btn svg {
        width: 24px;
        height: 24px;
      }

      /* ── Mobile Menu (Popover) ── */
      .mobile-menu {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        margin: 0;
        padding: 0;
        border: none;
        background: #f5f3ef;
        z-index: 200;
        opacity: 0;
        transform: translateX(100%);
        transition: opacity 0.3s ease, transform 0.3s ease, display 0.3s ease allow-discrete;
      }
      .mobile-menu:popover-open {
        opacity: 1;
        transform: translateX(0);
      }
      @starting-style {
        .mobile-menu:popover-open {
          opacity: 0;
          transform: translateX(100%);
        }
      }
      .mobile-menu-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px 32px;
      }
      .mobile-menu-logo {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: 'Poppins', sans-serif;
        font-size: 28px;
        font-weight: 600;
        color: #2D5143;
        letter-spacing: -0.96px;
      }
      .mobile-menu-logo svg {
        width: 20px;
        height: 20px;
        color: #2D5143;
      }
      .mobile-menu-close {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        padding: 8px;
        cursor: pointer;
        color: #2D5143;
      }
      .mobile-menu-close svg {
        width: 24px;
        height: 24px;
      }
      .mobile-menu-nav {
        display: flex;
        flex-direction: column;
        padding: 40px 32px;
        gap: 12px;
      }
      .mobile-menu-nav a {
        font-family: 'Poppins', sans-serif;
        font-size: 22px;
        font-weight: 600;
        color: #2D5143;
        padding: 8px 0;
      }
      .mobile-menu-nav a.active {
        color: #AE3A00;
      }
      .mobile-menu-login {
        display: none;
        padding: 0 32px;
      }
      .mobile-menu-login button,
      .mobile-menu-login span {
        font-family: 'Poppins', sans-serif;
        font-size: 22px;
        font-weight: 600;
        color: #2D5143;
        background: none;
        border: none;
        padding: 8px 0;
        cursor: pointer;
      }

      @media (max-width: 1000px) {
        .home-nav { display: none; }
        .hamburger-btn { display: flex; }
      }

      @media (max-width: 750px) {
        .home-header { padding: 50px 50px 0; margin-bottom: -97px; }
        .home-header-inner { padding: 0 16px; gap: 12px; }
        .home-action-text { display: none; }
        .home-search-label { display: none; }
        .mobile-menu-login { display: block; }
      }

      /* ── Hero Section ── */
      .hero {
        position: relative;
        aspect-ratio: 19 / 10;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        text-align: left;
        background: linear-gradient(135deg, #e87a4a 0%, #d4643a 30%, #3d7a5e 70%, #2d5d45 100%);
        color: #fff;
        overflow: hidden;
        padding: 60px 40px 40px;
        margin: 25px;
        border-radius: 20px;
      }

      @keyframes hero-float-in {
        0% {
          opacity: 0;
          transform: translateY(30px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .hero-bg-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        animation: hero-float-in 0.7s ease-out both;
      }

      @keyframes hero-slide-up {
        0% {
          transform: translateY(100%);
        }
        100% {
          transform: translateY(0);
        }
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 800px;
      }

      .hero-line-clip {
        overflow: hidden;
      }

      .hero-line-clip > * {
        animation: hero-slide-up 0.8s ease-out both;
      }

      .hero-line-clip:nth-child(2) > * {
        animation-delay: 0.15s;
      }

      .hero-line-clip:nth-child(3) > * {
        animation-delay: 0.3s;
      }

      .hero h1 {
        font-family: 'Poppins', sans-serif;
        font-size: clamp(12px, 6.3vw, 120px);
        font-weight: 600;
        line-height: 1;
        margin-bottom: 0;
        letter-spacing: -0.03em;
        color: #F2F0EB;
      }

      .hero p {
        font-family: 'kepler-w03-light-scd-cp', serif;
        font-size: clamp(12px, 3.19vw, 64px);
        font-weight: 400;
        font-style: normal;
        margin-bottom: 15px;
        line-height: 1.3;
        color: #F2F0EB;
      }

      .hero .btn-cta {
        font-family: poppins-semibold, 'Poppins', sans-serif;
        font-weight: 600;
        padding: 10px 64px;
        font-size: 20px;
        background: transparent;
        color: #F2F0EB;
        border: 2px solid rgba(255, 255, 255, 0.8);
        border-radius: var(--radius-lg);
      }

      .hero .btn-cta:hover {
        background: rgba(255, 255, 255, 0.15);
        border-color: #fff;
      }

      @media (max-width: 1000px) {
        .hero {
          aspect-ratio: 4 / 3;
        }
      }

      @media (max-width: 750px) {
        .hero {
          aspect-ratio: 1 / 2;
        }
        .hero h1 {
          font-size: clamp(12px, 12.27vw, 92px);
        }
        .hero p {
          font-size: clamp(12px, 6.67vw, 50px);
        }
      }

      .best-sellers-clip {
        overflow: clip;
      }

      .best-sellers {
        background: var(--bg-primary);
        padding: 64px 0;
        margin: 0 25px;
        position: sticky;
        top: 0;
        z-index: 1;
      }

      .best-sellers-inner {
        width: 100%;
      }

      .best-sellers-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        animation: hero-float-in 1s ease-out both;
        animation-timeline: view();
        animation-range: entry 0% entry 30%;
      }

      .best-sellers-header .section-title {
        font-family: 'Poppins', sans-serif;
        font-size: clamp(12px, 2.19vw, 45px);
        font-weight: 600;
        color: #2D5143;
      }

      .view-more-link {
        font-family: 'Poppins', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
        padding: 10px 28px;
        border: 2px solid var(--border, #d4d4d4);
        border-radius: 8px;
        transition: background-color 0.2s ease, border-color 0.2s ease;
      }

      .view-more-link:hover {
        background-color: var(--bg-secondary, #f5f5f5);
        border-color: var(--text-primary);
      }

      .best-sellers-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        animation: hero-float-in 1s ease-out both;
        animation-timeline: view();
        animation-range: entry 0% entry 30%;
      }

      .best-sellers .product-card {
        border-radius: 0;
        background: transparent;
        box-shadow: none;
      }

      .best-sellers .product-card:hover {
        box-shadow: none;
        transform: none;
      }

      .best-sellers .product-card-image {
        aspect-ratio: 4 / 5;
        border-radius: 20px;
      }

      .best-sellers .product-card-content {
        padding: 12px 4px;
        background: transparent;
      }

      .best-seller-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        z-index: 2;
        background: #bdd8f1;
        color: var(--text-primary);
        font-family: poppins-extralight, poppins, sans-serif;
        font-size: 12px;
        font-weight: 400;
        padding: 3px 10px;
        border-radius: 2px;
        letter-spacing: 0.02em;
      }

      /* ── Full-width Banner (between best sellers & roller) ── */
      .fold3-banner-wrapper {
        position: relative;
        z-index: 2;
        margin: 0 25px;
        padding: 25px 0;
        background: var(--bg-primary);
      }

      .fold3-banner {
        position: relative;
        aspect-ratio: 19 / 10;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        overflow: hidden;
        border-radius: 20px 20px 0 0;
        animation: hero-float-in 1s ease-out both;
        animation-timeline: view();
        animation-range: entry 0% entry 30%;
      }

      .fold3-banner-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
      }

      .fold3-banner-content {
        position: relative;
        z-index: 2;
        padding: 60px 40px 40px;
        max-width: 800px;
      }

      .fold3-banner-content h2 {
        font-family: 'Poppins', sans-serif;
        font-size: clamp(12px, 3.28vw, 64px);
        font-weight: 600;
        line-height: 1.1;
        color: #2B312F;
        margin-bottom: 8px;
        letter-spacing: -0.03em;
      }

      .fold3-banner-content p {
        font-family: 'kepler-w03-light-scd-cp', serif;
        font-size: clamp(12px, 3.28vw, 64px);
        font-weight: 400;
        line-height: 1;
        color: #2B312F;
        margin-bottom: 20px;
      }

      .fold3-banner-content .btn-banner {
        font-family: 'Poppins', sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 36px;
        font-size: 20px;
        font-weight: 600;
        color: #2B312F;
        background: transparent;
        border: 2px solid #2B312F;
        border-radius: var(--radius-lg);
        text-transform: lowercase;
        letter-spacing: 0.02em;
        transition: background-color 0.2s ease, border-color 0.2s ease;
      }

      .fold3-banner-content .btn-banner:hover {
        background: rgba(0, 0, 0, 0.08);
        border-color: #2d3436;
      }

      @media (max-width: 750px) {
        .fold3-banner-content {
          padding: 32px 24px;
          max-width: 100%;
        }
      }

      .shipping-banner {
        background: #d5e955;
        border-radius: 0 0 20px 20px;
        padding: 16px 0;
        overflow: hidden;
      }

      .marquee {
        display: flex;
        gap: 48px;
        animation: marquee 20s linear infinite;
        white-space: nowrap;
      }

      .marquee span {
        font-family: 'Poppins', sans-serif;
        font-size: clamp(12px, 3.28vw, 24px);
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      .shop-by-category {
        position: relative;
        z-index: 2;
        background: var(--bg-primary);
        padding: 40px 25px 80px;
      }

      .shop-by-category-inner {
        width: 100%;
      }

      .shop-by-category-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
      }

      .shop-by-category h2 {
        font-family: 'Poppins', sans-serif;
        text-align: left;
        font-size: clamp(12px, 2.19vw, 45px);
        font-weight: 600;
        color: #2D5143;
        margin-bottom: 0;
      }

      .shop-by-category .btn-shop-now {
        font-family: 'Poppins', sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 28px;
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
        background: transparent;
        border: 2px solid var(--border, #d4d4d4);
        border-radius: 8px;
        text-transform: lowercase;
        letter-spacing: 0.02em;
        transition: background-color 0.2s ease, border-color 0.2s ease;
      }

      .shop-by-category .btn-shop-now:hover {
        background: rgba(0, 0, 0, 0.08);
        border-color: #2B312F;
      }

      .category-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .category-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        border-radius: var(--radius-xl);
        border: none;
        background: #e0ddd9;
        padding: 29px;
        gap: 12px;
        transition: transform var(--transition-base), background-color 0.3s ease;
      }

      .category-card:hover { transform: translateY(-4px); }

      .category-card:nth-child(1):hover { background-color: #bdd8f1; }
      .category-card:nth-child(2):hover { background-color: #e8874a; }
      .category-card:nth-child(3):hover { background-color: #d5e955; }

      .category-card img {
        width: 100%;
        aspect-ratio: 3/4;
        object-fit: cover;
        border-radius: calc(var(--radius-xl) - 6px);
      }

      .category-card-label {
        font-family: 'Poppins', sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 30px;
        border: 2px solid #2D5143;
        border-radius: var(--radius-lg);
        font-size: clamp(12px, 3.56vw, 64px);
        font-weight: 600;
        text-align: center;
        color: #2D5143;
        background: transparent;
        margin-bottom: 4px;
      }

      .our-story-wrapper {
        position: relative;
        z-index: 2;
        margin: 0 25px 0 25px;
        background: var(--bg-primary);
        height: 160vw;
      }

      @keyframes our-story-rise {
        0% {
          opacity: 0;
          transform: translateY(60px) scale(0.98);
        }
        100% {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      /* Layer 1: background (bottom) */
      .our-story-background {
        position: sticky;
        top: 13vh;
        background: #a0c8ff;
        text-align: center;
        padding: 100px var(--page-padding);
        border-radius: 20px;
        z-index: 1;
        height: 40vw;
        color: transparent;
        animation: our-story-rise 1s ease-out both;
        animation-timeline: view();
        animation-range: entry 0% entry 30%;
      }

      /* Layer 3: text (top) */
      .our-story-text {
        position: sticky;
        top: 13vh;
        z-index: 3;
        height: 40vw;
        overflow: visible;
        pointer-events: none;
        margin-top: calc(-40vw)
      }

      .our-story-text-content {
        text-align: center;
        color: #2D5143;
        padding: clamp(50px, 7vw, 150px) var(--page-padding);
        pointer-events: auto;
        width: 78%;
        margin: auto;
      }

      .our-story-text-content h2 {
          font-family: 'Poppins', sans-serif;
          font-size: clamp(12px, 4vw, 64px);
          font-weight: 600;
          text-transform: lowercase;
          letter-spacing: 0.02em;
          margin-bottom: 16px;
          color: #2D5143;
      }

      .our-story-text-content p {
          font-family: 'kepler-w03-light-scd-cp', serif;
          font-size: clamp(12px, 5vw, 90px);
          font-weight: 400;
          font-style: normal;
          line-height: 1;
          margin: 0 auto 16px;
          color: #2D5143;
      }

      .our-story-text-content .tagline {
          font-family: 'Poppins', sans-serif;
          font-size: 14px;
          font-weight: 200;
          font-style: normal;
          opacity: 1;
          letter-spacing: 0.05em;
          color: #2D5143;
      }

      /* Layer 2: images (middle) */
      .our-story-float-right {
        position: sticky;
        top: 18vw;
        height: 0;
        z-index: 2;
        pointer-events: none;
        margin-top: 30vw;
        margin-bottom: 30vw;
      }

      .our-story-float-left {
        position: sticky;
        top: 13vw;
        height: 0;
        z-index: 2;
        pointer-events: none;
        margin-top: 70vw;
        margin-bottom: 35vw;
      }

      .our-story-img-left,
      .our-story-img-right {
        position: absolute;
        pointer-events: auto;
      }

      .our-story-img-left {
        left: 60px;
        top: 30px;
        width: clamp(100px, 15vw, 350px);
        object-fit: contain;
        animation: float-gentle 6s ease-in-out infinite;
      }

      @keyframes float-gentle {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
      }

      .our-story-img-right {
        right: 80px;
        top: 40px;
        width: clamp(80px, 15vw, 450px);
        object-fit: contain;
        animation: float-complex 23s ease-in-out infinite;
      }

      @keyframes float-complex {
        0% { transform: translateY(0); }
        13% { transform: translateY(-20px); }
        26% { transform: translateY(0); }
        39% { transform: translateY(-8px); }
        52% { transform: translateY(0); }
        74% { transform: translateY(0); }
        87% { transform: translateY(-12px); }
        100% { transform: translateY(0); }
      }

      @media (max-width: 750px) {
        .our-story-wrapper {
          padding-bottom: 600px;
        }
        .our-story-float-right {
          margin-top: 200px;
        }
        .our-story-float-left {
          margin-top: 400px;
        }
        .our-story-img-left {
          left: 10px;
          top: 20px;
        }
        .our-story-img-right {
          right: 10px;
          top: 30px;
        }
      }

      .instagram-section {
        position: relative;
        z-index: 2;
        background: var(--bg-secondary);
        color: var(--text-primary);
        text-align: center;
        padding: 64px 0;
      }

      .instagram-icon {
        display: flex;
        justify-content: center;
        margin-bottom: 16px;
      }

      .instagram-icon svg {
        width: 40px;
        height: 40px;
      }

      .instagram-section h2 {
        font-family: 'Poppins', sans-serif;
        font-size: clamp(12px, 3vw, 64px);
        font-weight: 600;
        margin-bottom: 8px;
        color: #2D5143;
      }

      .instagram-section p {
        font-family: 'kepler-w03-light-scd-cp', serif;
        font-weight: 200;
        font-size: clamp(12px, 3vw, 50px);;
        color: var(--text-secondary);
        margin-bottom: 32px;
      }

      .instagram-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        overflow: hidden;
      }

      .ig-row {
        display: flex;
        gap: 16px;
        will-change: transform;
      }

      .ig-row-1 {
        animation: ig-scroll-left linear both;
        animation-timeline: scroll(root);
      }

      .ig-row-2 {
        animation: ig-scroll-right linear both;
        animation-timeline: scroll(root);
      }

      @keyframes ig-scroll-left {
        from { transform: translateX(300px); }
        to { transform: translateX(-100px); }
      }

      @keyframes ig-scroll-right {
        from { transform: translateX(-400px); }
        to { transform: translateX(000px); }
      }

      .ig-row .ig-image {
        width: 22vw;
        height: 22vw;
        max-width: 420px;
        max-height: 420px;
        flex-shrink: 0;
        background: var(--bg-primary);
        border-radius: var(--radius-xl);
        overflow: hidden;
      }

      .instagram-grid .ig-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      @media (max-width: 1000px) {
        .fold3-banner {
          aspect-ratio: unset;
          height: 53vw;
        }
        .view-more-link { font-size: 14px; }
        .shop-by-category .btn-shop-now { font-size: 14px; }
        .best-sellers-grid {
          display: flex;
          overflow-x: auto;
          scroll-snap-type: x mandatory;
          scroll-behavior: smooth;
          -webkit-overflow-scrolling: touch;
          gap: 16px;
          padding: 0 5%;
          scrollbar-width: none;
        }
        .best-sellers-grid::-webkit-scrollbar {
          display: none;
        }
        .best-sellers-grid .product-card {
          scroll-snap-align: center;
          flex: 0 0 clamp(300px, 40vw, 400px);
        }
        .best-sellers .product-card-image {
          aspect-ratio: 400 / 520;
        }
      }

      @media (max-width: 750px) {
        .best-sellers { padding: 48px 0; }
        .fold3-banner {
          aspect-ratio: unset;
          height: 134.67vw;
          width: 100%;
          margin: 0 auto;
        }
        .best-sellers-header { margin-bottom: 24px; gap: 16px; }
        .best-sellers-header .section-title { font-size: clamp(12px, 5vw, 32px); }
        .view-more-link { padding: 8px 20px; }
        .shop-by-category h2 { font-size: clamp(12px, 5vw, 32px); }
        .shop-by-category .btn-shop-now { padding: 8px 20px; }
        .best-sellers-grid {
          padding: 0;
        }
        .best-sellers-grid .product-card {
          flex: 0 0 80%;
        }
        .best-sellers .product-card-image {
          aspect-ratio: 4 / 5;
        }
        .category-cards { grid-template-columns: 1fr; }
        .instagram-grid { grid-template-columns: repeat(2, 1fr); gap: clamp(4px, 2.5vw, 16px)}

        .our-story-wrapper {height: 95vw; padding-bottom: 0}
        .our-story-float-right {margin-top: -60vw;margin-bottom: 0}
        .our-story-float-left {margin-top: -80vw;margin-bottom: 0}
        .our-story-text-content {padding-top: 10%; width: 95%}
        .our-story-text-content h2 { font-size: clamp(12px, 5.27vw, 32px); }
        .our-story-text-content p { font-size: clamp(12px, 8.23vw, 64px); }
        .our-story-background {height: 95vw}
        .our-story-text {
            height: 95vw;
            margin-top: -95vw
        }
        .ig-row {gap: clamp(4px, 2.5vw, 16px);}
        .footer-col a { margin-bottom: 2px; }
        .footer-col p { margin-bottom: 2px; }
        .footer-col h3 { margin-bottom: 10px; }
      }
    </style>
  </head>
  <body>
    <main class="home-page">
      <header class="home-header {headerReady ? header-ready} {headerHidden ? header-hidden} {headerHasScrolled ? header-has-scrolled}">
        <div class="home-header-bar">
          <div class="home-header-inner">
            <a href="/" class="home-logo"><span class="home-logo-icon"><svg preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 19.009 19" height="19" width="19" role="presentation" aria-hidden="true"><path fill="currentColor" d="M16.392 9.5A2.626 2.626 0 0 0 19 6.875a2.63 2.63 0 0 0-2.624-2.626c-.723 0-1.412.149-2.04.413a5.2 5.2 0 0 0 .413-2.04A2.62 2.62 0 0 0 12.124.003 2.62 2.62 0 0 0 9.5 2.607 2.626 2.626 0 0 0 6.876 0 2.63 2.63 0 0 0 4.25 2.625c0 .723.147 1.413.413 2.04a5.25 5.25 0 0 0-2.04-.413A2.623 2.623 0 0 0 .002 6.877a2.62 2.62 0 0 0 2.606 2.624A2.626 2.626 0 0 0 0 12.126a2.627 2.627 0 0 0 2.624 2.624 5.2 5.2 0 0 0 2.04-.413 5.2 5.2 0 0 0-.413 2.04 2.62 2.62 0 0 0 2.625 2.621A2.62 2.62 0 0 0 9.5 16.393 2.626 2.626 0 0 0 12.124 19a2.63 2.63 0 0 0 2.625-2.625c0-.723-.147-1.412-.413-2.04a5.2 5.2 0 0 0 2.04.413 2.624 2.624 0 0 0 .016-5.249m-6.895 1.626c-.723 0-1.414.148-2.04.413a5.2 5.2 0 0 0 .413-2.04 5.2 5.2 0 0 0-.413-2.04 5.2 5.2 0 0 0 2.04.413 5.2 5.2 0 0 0 2.04-.412 5.2 5.2 0 0 0-.413 2.04c0 .722.147 1.412.413 2.039a5.25 5.25 0 0 0-2.04-.413"/></svg></span> onsko</a>
            <nav class="home-nav">
              <a href="/" class="active">home</a>
              <a href="/products">shop</a>
              <a href="#our-story">about</a>
            </nav>
            <div class="home-header-actions">
              <jay:login-indicator>
                <button if="!isLoggedIn" ref="loginButton" class="home-action-text home-login-btn">log in</button>
                <span if="isLoggedIn" class="home-action-text">{memberName}</span>
                <button if="isLoggedIn" ref="logoutButton" class="home-action-text home-login-btn">log out</button>
              </jay:login-indicator>
              <jay:cart-indicator>
                <a href="/cart" class="home-cart-indicator {hasItems ? has-items} {isLoading ? is-loading} {justAdded ? just-added}" ref="cartLink">
                  <span class="home-cart-badge">{itemCount}</span>
                </a>
              </jay:cart-indicator>
              <button class="hamburger-btn" popovertarget="mobile-menu" aria-label="Open menu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
              </button>
            </div>
          </div>
        </div>
      </header>

      <div id="mobile-menu" popover class="mobile-menu">
        <div class="mobile-menu-header">
          <a href="/" class="mobile-menu-logo"><svg preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 19.009 19" height="19" width="19" role="presentation" aria-hidden="true"><path fill="currentColor" d="M16.392 9.5A2.626 2.626 0 0 0 19 6.875a2.63 2.63 0 0 0-2.624-2.626c-.723 0-1.412.149-2.04.413a5.2 5.2 0 0 0 .413-2.04A2.62 2.62 0 0 0 12.124.003 2.62 2.62 0 0 0 9.5 2.607 2.626 2.626 0 0 0 6.876 0 2.63 2.63 0 0 0 4.25 2.625c0 .723.147 1.413.413 2.04a5.25 5.25 0 0 0-2.04-.413A2.623 2.623 0 0 0 .002 6.877a2.62 2.62 0 0 0 2.606 2.624A2.626 2.626 0 0 0 0 12.126a2.627 2.627 0 0 0 2.624 2.624 5.2 5.2 0 0 0 2.04-.413 5.2 5.2 0 0 0-.413 2.04 2.62 2.62 0 0 0 2.625 2.621A2.62 2.62 0 0 0 9.5 16.393 2.626 2.626 0 0 0 12.124 19a2.63 2.63 0 0 0 2.625-2.625c0-.723-.147-1.412-.413-2.04a5.2 5.2 0 0 0 2.04.413 2.624 2.624 0 0 0 .016-5.249m-6.895 1.626c-.723 0-1.414.148-2.04.413a5.2 5.2 0 0 0 .413-2.04 5.2 5.2 0 0 0-.413-2.04 5.2 5.2 0 0 0 2.04.413 5.2 5.2 0 0 0 2.04-.412 5.2 5.2 0 0 0-.413 2.04c0 .722.147 1.412.413 2.039a5.25 5.25 0 0 0-2.04-.413"/></svg> onsko</a>
          <button popovertarget="mobile-menu" popovertargetaction="hide" class="mobile-menu-close" aria-label="Close menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
          </button>
        </div>
        <nav class="mobile-menu-nav">
          <a href="/" class="active">home</a>
          <a href="/products">shop</a>
          <a href="#our-story">about</a>
        </nav>
        <div class="mobile-menu-login">
          <jay:login-indicator>
            <button if="!isLoggedIn" ref="loginButton" class="mobile-login-btn" popovertarget="mobile-menu" popovertargetaction="hide">log in</button>
            <span if="isLoggedIn">{memberName}</span>
            <button if="isLoggedIn" ref="logoutButton" class="mobile-login-btn" popovertarget="mobile-menu" popovertargetaction="hide">log out</button>
          </jay:login-indicator>
        </div>
      </div>

      <section class="hero">
        <img class="hero-bg-image" src="https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_1920,h_1080/file.webp" srcset="https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_640%2Ch_360/file.webp 640w, https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_1200%2Ch_675/file.webp 1200w, https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_1920%2Ch_1080/file.webp 1920w" sizes="100vw" alt="Onsko beauty products" loading="eager" width="1920" height="1080" fetchpriority="high" />
        <div class="hero-content">
          <div class="hero-line-clip"><h1>shine on</h1></div>
          <div class="hero-line-clip"><p>beauty that reflects your spirit</p></div>
          <div class="hero-line-clip"><a href="/products" class="btn btn-cta btn-lg">shop now</a></div>
        </div>
      </section>

      <div class="best-sellers-clip">
        <jay:category-products categorySlug="best-sellers" limit="4">
          <section class="best-sellers">
            <div class="best-sellers-inner">
              <div class="best-sellers-header">
                <h2 class="section-title">best sellers</h2>
                <a href="/products/best-sellers" class="view-more-link">view more</a>
              </div>
              <div class="best-sellers-grid">
                <a href="{productUrl}" class="product-card" forEach="products" trackBy="_id">
                  <div class="product-card-image">
                    <span class="best-seller-badge">best seller</span>
                    <img src="{thumbnail.url}/v1/fill/w_600,h_600/file.webp" srcset="{thumbnail.url}/v1/fill/w_300%2Ch_300/file.webp 300w, {thumbnail.url}/v1/fill/w_400%2Ch_400/file.webp 400w, {thumbnail.url}/v1/fill/w_600%2Ch_600/file.webp 600w" sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 25vw" alt="{thumbnail.altText}" loading="lazy" width="600" height="600" />
                  </div>
                  <div class="product-card-content">
                    <h3 class="product-card-name">{name}</h3>
                    <div class="product-card-price"><span class="current-price">{price}</span></div>
                  </div>
                </a>
              </div>
            </div>
          </section>
        </jay:category-products>

          <div class="fold3-banner-wrapper">
              <section class="fold3-banner">
                  <img class="fold3-banner-bg" src="https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0,y_514,w_2688,h_1278/fill/w_1437,h_683,fp_0.50_0.50,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/fold3_banner.jpg" srcset="https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0%2Cy_514%2Cw_2688%2Ch_1278/fill/w_640%2Ch_304%2Cfp_0.50_0.50%2Cq_85%2Cusm_0.66_1.00_0.01%2Cenc_avif%2Cquality_auto/fold3_banner.jpg 640w, https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0%2Cy_514%2Cw_2688%2Ch_1278/fill/w_1200%2Ch_570%2Cfp_0.50_0.50%2Cq_85%2Cusm_0.66_1.00_0.01%2Cenc_avif%2Cquality_auto/fold3_banner.jpg 1200w, https://static.wixstatic.com/media/c837a6_ce2611b99f714d55ac39dd982c0e2dc3~mv2.jpg/v1/crop/x_0%2Cy_514%2Cw_2688%2Ch_1278/fill/w_1437%2Ch_683%2Cfp_0.50_0.50%2Cq_85%2Cusm_0.66_1.00_0.01%2Cenc_avif%2Cquality_auto/fold3_banner.jpg 1437w" sizes="100vw" alt="Onsko new arrivals banner" loading="lazy" width="1437" height="683" />
                  <div class="fold3-banner-content">
                      <h2>effortless beauty, timeless charm.</h2>
                      <p>new arrivals now in stock</p>
                      <a href="/products" class="btn-banner">shop now</a>
                  </div>
              </section>
              <div class="shipping-banner">
                  <div class="marquee">
                      <span>✻ free shipping on orders over $50</span>
                      <span>✻ free shipping on orders over $50</span>
                      <span>✻ free shipping on orders over $50</span>
                      <span>✻ free shipping on orders over $50</span>
                      <span>✻ free shipping on orders over $50</span>
                      <span>✻ free shipping on orders over $50</span>
                      <span>✻ free shipping on orders over $50</span>
                      <span>✻ free shipping on orders over $50</span>
                  </div>
              </div>
          </div>
      </div>


      <section class="shop-by-category">
        <div class="shop-by-category-inner">
          <div class="shop-by-category-header">
            <h2>shop by category</h2>
            <a href="/products" class="btn-shop-now">shop now</a>
          </div>
          <div class="category-cards">
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_600,h_800/file.webp" srcset="https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_300%2Ch_400/file.webp 300w, https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_400%2Ch_533/file.webp 400w, https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_600%2Ch_800/file.webp 600w" sizes="(max-width: 768px) 100vw, 33vw" alt="Face products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">face</span>
            </a>
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_600,h_800/file.webp" srcset="https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_300%2Ch_400/file.webp 300w, https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_400%2Ch_533/file.webp 400w, https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_600%2Ch_800/file.webp 600w" sizes="(max-width: 768px) 100vw, 33vw" alt="Body products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">body</span>
            </a>
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_600,h_800/file.webp" srcset="https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_300%2Ch_400/file.webp 300w, https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_400%2Ch_533/file.webp 400w, https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_600%2Ch_800/file.webp 600w" sizes="(max-width: 768px) 100vw, 33vw" alt="Hair products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">hair</span>
            </a>
          </div>
        </div>
      </section>

      <div id="our-story" class="our-story-wrapper">
        <section class="our-story-background">
        </section>
        <div class="our-story-text">
          <div class="our-story-text-content">
            <h2>our story</h2>
            <p>born from a passion for beauty rituals, we celebrate individuality and bring radiant confidence to everyone</p>
            <p class="tagline">for every body, anywhere</p>
          </div>
        </div>
        <div class="our-story-float-right">
          <img class="our-story-img-right" src="https://static.wixstatic.com/media/c569b3_1fc3ec35a43b4a83a87e492e4c7165e2~mv2.png/v1/fill/w_300,h_500/file.png" srcset="https://static.wixstatic.com/media/c569b3_1fc3ec35a43b4a83a87e492e4c7165e2~mv2.png/v1/fill/w_150%2Ch_250/file.png 150w, https://static.wixstatic.com/media/c569b3_1fc3ec35a43b4a83a87e492e4c7165e2~mv2.png/v1/fill/w_300%2Ch_500/file.png 300w" sizes="12vw" alt="Onsko beauty product" loading="lazy" width="300" height="500" />
        </div>
        <div class="our-story-float-left">
          <img class="our-story-img-left" src="https://static.wixstatic.com/media/c569b3_4692c37200824c34914df0c51b8644a7~mv2.png/v1/fill/w_400,h_400/file.png" srcset="https://static.wixstatic.com/media/c569b3_4692c37200824c34914df0c51b8644a7~mv2.png/v1/fill/w_200%2Ch_200/file.png 200w, https://static.wixstatic.com/media/c569b3_4692c37200824c34914df0c51b8644a7~mv2.png/v1/fill/w_400%2Ch_400/file.png 400w" sizes="15vw" alt="Onsko beauty highlight" loading="lazy" width="400" height="400" />
        </div>
      </div>

      <section class="instagram-section">
        <div class="instagram-icon">
          <svg preserveAspectRatio="xMidYMid meet" data-bbox="7 7 42 42" xmlns="http://www.w3.org/2000/svg" viewBox="7 7 42 42" height="56" width="56" role="presentation" aria-hidden="true">
            <g>
