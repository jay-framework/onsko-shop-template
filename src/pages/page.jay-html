<html>
  <head>
    <title>Onsko | Clean Beauty Products</title>
    <meta name="description" content="Discover clean beauty products for face, body, and hair. Beauty that reflects your spirit.">
    <script type="application/jay-headless" plugin="@jay-framework/wix-cart" contract="cart-indicator"></script>
    <script type="application/jay-headless" plugin="@jay-framework/wix-stores" contract="product-search"></script>
    <script type="application/jay-headfull" src="../components/site-footer/site-footer" names="SiteFooter" contract="../components/site-footer/site-footer.jay-contract"></script>
    <script type="application/jay-data" contract="./page.jay-contract"></script>
    <link rel="stylesheet" href="../styles/onsko-theme.css" />
    <style>
      /* ── White body for hero gap ── */
      body { background: #ffffff; }

      /* ── Homepage Unique Header ── */
      .home-header {
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 50px 50px 0;
        margin-bottom: -97px;
        transition: transform 0.5s ease, opacity 0.5s ease;
      }

      .home-header.header-hidden {
        transform: translateY(-110%);
        opacity: 0;
        transition: transform 0.5s ease 0.2s, opacity 0.5s ease 0.5s;
      }

      .home-header-bar {
        background: #ffffff;
        border-radius: var(--radius-full);
        box-shadow: var(--shadow-md);
        height: 47px;
      }

      .home-header-inner {
        max-width: var(--container-max);
        margin: 0 auto;
        display: flex;
        align-items: center;
        height: 100%;
        padding: 0 24px;
        gap: 32px;
      }

      .home-logo {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: 0.02em;
        white-space: nowrap;
      }

      .home-logo-icon {
        color: var(--accent);
        font-size: 24px;
      }

      .home-nav {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .home-nav a {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        padding: 4px 0;
        transition: color var(--transition-fast);
      }

      .home-nav a:hover {
        color: var(--text-primary);
      }

      .home-header-actions {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
        color: var(--text-primary);
      }

      .home-action-text {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        transition: color var(--transition-fast);
        white-space: nowrap;
      }

      .home-action-text:hover {
        color: var(--text-primary);
      }

      .home-action-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        transition: color var(--transition-fast);
      }

      .home-action-icon:hover {
        color: var(--text-primary);
      }

      .home-cart-indicator {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      .home-cart-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 24px;
        height: 24px;
        padding: 0 6px;
        background: var(--success);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        border-radius: var(--radius-full);
      }

      .home-cart-indicator.just-added {
        animation: cart-flash 0.4s ease;
      }

      .home-search-label {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        white-space: nowrap;
      }

      @media (max-width: 768px) {
        .home-header { padding: 24px 16px 0; margin-bottom: -71px; }
        .home-header-inner { padding: 0 16px; gap: 16px; }
        .home-nav { gap: 14px; }
        .home-header-actions { gap: 12px; }
        .home-search-label { display: none; }
        .home-action-text { display: none; }
      }

      @media (max-width: 600px) {
        .home-header-inner { flex-wrap: wrap; gap: 10px; }
        .home-nav a { font-size: 13px; }
      }

      /* ── Hero Section ── */
      .hero {
        position: relative;
        min-height: 80vh;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        text-align: left;
        background: linear-gradient(135deg, #e87a4a 0%, #d4643a 30%, #3d7a5e 70%, #2d5d45 100%);
        color: #fff;
        overflow: hidden;
        padding: 60px 40px 40px;
        margin: 25px;
        border-radius: 20px;
      }

      .hero-bg-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 520px;
      }

      .hero h1 {
        font-size: clamp(48px, 10vw, 96px);
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0;
        letter-spacing: -0.02em;
      }

      .hero p {
        font-family: var(--font-primary);
        font-size: clamp(18px, 2.5vw, 24px);
        font-style: normal;
        opacity: 0.95;
        margin-bottom: 15px;
        font-weight: 400;
        line-height: 1.3;
      }

      .hero .btn-cta {
        padding: 10px 64px;
        font-size: 18px;
        background: transparent;
        color: #fff;
        border: 2px solid rgba(255, 255, 255, 0.8);
        border-radius: var(--radius-lg);
      }

      .hero .btn-cta:hover {
        background: rgba(255, 255, 255, 0.15);
        border-color: #fff;
      }

      .best-sellers {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 64px var(--page-padding);
        background: var(--bg-primary);
      }

      .best-sellers-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
      }

      .view-more-link {
        font-size: 14px;
        font-weight: 600;
        color: var(--accent);
      }

      .view-more-link:hover { text-decoration: underline; }

      .best-sellers-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
      }

      .best-sellers .product-card {
        border-radius: 0;
        background: transparent;
        box-shadow: none;
      }

      .best-sellers .product-card:hover {
        box-shadow: none;
        transform: none;
      }

      .best-sellers .product-card-image {
        aspect-ratio: 4 / 5;
        border-radius: 20px;
      }

      .best-sellers .product-card-content {
        padding: 12px 4px;
        background: transparent;
      }

      .best-seller-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        z-index: 2;
        background: var(--bg-header);
        color: #fff;
        font-size: 12px;
        font-weight: 600;
        padding: 5px 14px;
        border-radius: var(--radius-full);
        letter-spacing: 0.02em;
      }

      .shipping-banner {
        background: var(--bg-card);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 16px 0;
        overflow: hidden;
      }

      .marquee {
        display: flex;
        gap: 48px;
        animation: marquee 20s linear infinite;
        white-space: nowrap;
      }

      .marquee span {
        font-size: 14px;
        font-weight: 600;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      .new-arrivals {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 80px var(--page-padding);
        text-align: center;
        background: var(--bg-primary);
      }

      .new-arrivals h2 {
        font-family: var(--font-serif);
        font-size: clamp(28px, 4vw, 40px);
        font-weight: 400;
        font-style: italic;
        margin-bottom: 8px;
        color: var(--text-primary);
      }

      .new-arrivals p {
        font-size: 15px;
        color: var(--text-secondary);
        margin-bottom: 32px;
      }

      .new-arrivals-images {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 32px;
      }

      .new-arrivals-images .image-placeholder {
        aspect-ratio: 4/5;
        background: var(--bg-product-image);
        border-radius: var(--radius-xl);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        font-size: 14px;
      }

      .shop-by-category {
        background: var(--bg-secondary);
        padding: 80px var(--page-padding);
      }

      .shop-by-category-inner {
        max-width: var(--container-max);
        margin: 0 auto;
      }

      .shop-by-category h2 {
        text-align: center;
        margin-bottom: 40px;
        font-size: 28px;
        font-weight: 600;
      }

      .category-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .category-card {
        position: relative;
        aspect-ratio: 3/4;
        border-radius: var(--radius-xl);
        overflow: hidden;
        background: var(--bg-product-image);
        display: flex;
        align-items: flex-end;
        transition: transform var(--transition-base);
      }

      .category-card:hover { transform: translateY(-4px); }

      .category-card img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .category-card-label {
        position: relative;
        z-index: 2;
        width: 100%;
        padding: 20px 24px;
        background: rgba(255,255,255,0.9);
        font-size: 18px;
        font-weight: 600;
        text-align: center;
        color: var(--text-primary);
      }

      .our-story {
        background: #3d7a5e;
        color: #fff;
        text-align: center;
        padding: 100px var(--page-padding);
      }

      .our-story h2 {
        font-size: 16px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 24px;
        opacity: 0.8;
      }

      .our-story p {
        font-family: var(--font-serif);
        font-size: clamp(24px, 3.5vw, 36px);
        font-weight: 400;
        font-style: italic;
        line-height: 1.4;
        max-width: 700px;
        margin: 0 auto 16px;
      }

      .our-story .tagline {
        font-family: var(--font-primary);
        font-size: 14px;
        font-style: normal;
        opacity: 0.7;
        letter-spacing: 0.05em;
      }

      .instagram-section {
        background: var(--bg-footer);
        color: #fff;
        text-align: center;
        padding: 64px var(--page-padding);
      }

      .instagram-section h2 {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 8px;
      }

      .instagram-section p {
        font-size: 14px;
        opacity: 0.6;
        margin-bottom: 32px;
      }

      .instagram-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 8px;
        max-width: 1000px;
        margin: 0 auto;
      }

      .instagram-grid .ig-image {
        aspect-ratio: 1;
        background: rgba(255,255,255,0.1);
        border-radius: var(--radius-md);
        overflow: hidden;
      }

      .instagram-grid .ig-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      @media (max-width: 1024px) {
        .best-sellers-grid { grid-template-columns: repeat(2, 1fr); }
      }

      @media (max-width: 768px) {
        .category-cards { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
        .new-arrivals-images { grid-template-columns: 1fr; }
        .instagram-grid { grid-template-columns: repeat(3, 1fr); }
      }

      @media (max-width: 600px) {
        .best-sellers-grid { grid-template-columns: 1fr; }
        .instagram-grid { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </head>
  <body>
    <main class="home-page">
      <header class="home-header {headerHidden ? header-hidden}">
        <div class="home-header-bar">
          <div class="home-header-inner">
            <a href="/" class="home-logo"><span class="home-logo-icon">✻</span> onsko</a>
            <nav class="home-nav">
              <a href="/">home</a>
              <a href="/products">shop</a>
              <a href="#">about</a>
              <a href="#">blog</a>
            </nav>
            <div class="home-header-actions">
              <a href="#" class="home-action-text">log in</a>
              <button class="home-action-icon" aria-label="Wishlist">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
              <jay:cart-indicator>
                <a href="/cart" class="home-cart-indicator {hasItems ? has-items} {isLoading ? is-loading} {justAdded ? just-added}" ref="cartLink">
                  <span class="home-cart-badge">{itemCount}</span>
                </a>
              </jay:cart-indicator>
              <span class="home-search-label">Search</span>
              <button class="home-action-icon" aria-label="Search">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
              </button>
            </div>
          </div>
        </div>
      </header>

      <section class="hero">
        <img class="hero-bg-image" src="https://static.wixstatic.com/media/c569b3_16f4fe34ac024db1a4f6fd3a685a8513~mv2.jpg/v1/fill/w_1920,h_1080/file.webp" alt="Onsko beauty products" loading="eager" width="1920" height="1080" fetchpriority="high" />
        <div class="hero-content">
          <h1>shine on</h1>
          <p>beauty that reflects your spirit</p>
          <a href="/products" class="btn btn-cta btn-lg">shop now</a>
        </div>
      </section>

      <jay:product-search category="best-sellers">
        <section class="best-sellers">
          <div class="best-sellers-header">
            <h2 class="section-title">best sellers</h2>
            <a href="/products" class="view-more-link">view more →</a>
          </div>
          <div class="best-sellers-grid">
            <a href="{productUrl}" class="product-card" forEach="searchResults" trackBy="_id">
              <div class="product-card-image">
                <span class="best-seller-badge">best seller</span>
                <img src="{thumbnail.url}/v1/fill/w_600,h_600/file.webp" alt="{thumbnail.altText}" loading="lazy" width="600" height="600" />
              </div>
              <div class="product-card-content">
                <h3 class="product-card-name">{name}</h3>
                <div class="product-card-price"><span class="current-price">{price}</span></div>
              </div>
            </a>
          </div>
        </section>
      </jay:product-search>

      <div class="shipping-banner">
        <div class="marquee">
          <span>✻ free shipping on orders over $50</span>
          <span>✻ free shipping on orders over $50</span>
          <span>✻ free shipping on orders over $50</span>
          <span>✻ free shipping on orders over $50</span>
          <span>✻ free shipping on orders over $50</span>
          <span>✻ free shipping on orders over $50</span>
          <span>✻ free shipping on orders over $50</span>
          <span>✻ free shipping on orders over $50</span>
        </div>
      </div>

      <section class="new-arrivals">
        <h2>effortless beauty, timeless charm.</h2>
        <p>new arrivals now in stock</p>
        <div class="new-arrivals-images">
          <img src="https://static.wixstatic.com/media/c569b3_f712cb28454c4f75b5f658ec9cfecae0~mv2.jpg/v1/fill/w_800,h_1000/file.webp" alt="New arrivals product" loading="lazy" width="800" height="1000" />
          <img src="https://static.wixstatic.com/media/c569b3_e82cca0081a24f539215c12ceea2f27f~mv2.jpg/v1/fill/w_800,h_1000/file.webp" alt="New arrivals product" loading="lazy" width="800" height="1000" />
        </div>
        <a href="/products" class="btn btn-cta">shop now</a>
      </section>

      <section class="shop-by-category">
        <div class="shop-by-category-inner">
          <h2>shop by category</h2>
          <div class="category-cards">
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_cf29fc0440cd480a806555212a919777~mv2.jpg/v1/fill/w_600,h_800/file.webp" alt="Face products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">face</span>
            </a>
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_049fc20e8f8d48738107db12853c1f5d~mv2.jpg/v1/fill/w_600,h_800/file.webp" alt="Body products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">body</span>
            </a>
            <a href="/products" class="category-card">
              <img src="https://static.wixstatic.com/media/c569b3_4dd2feb1e0f646bba2cd5f9cd5802189~mv2.jpg/v1/fill/w_600,h_800/file.webp" alt="Hair products" loading="lazy" width="600" height="800" />
              <span class="category-card-label">hair</span>
            </a>
          </div>
        </div>
      </section>

      <section class="our-story">
        <h2>our story</h2>
        <p>born from a passion for beauty rituals, we celebrate individuality and bring radiant confidence to everyone</p>
        <p class="tagline">for every body, anywhere</p>
      </section>

      <section class="instagram-section">
        <h2>Follow Us on Instagram</h2>
        <p>#onsko_beauty</p>
        <div class="instagram-grid">
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_a9c56931a8584d80aa7b1fa26d3b6fab~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_1bd7d185cb8a43e380138168bb3fb7c4~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_5c2838e71e5b4d1697fc1ed7cfd8e534~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_888ea433600044d0bb78c88db94f532b~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_a3d6d1e4a8fa48f899460c35095b7524~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_a819ead9b3b04405aa30d59dc840b5d0~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_d932ea27531f42dbb91ab57d9ff68687~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_c8bfc03eaabc4ce8bc38d5e558f8f712~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_8bf48c1f406f46a4bd02629af619b3c7~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
          <div class="ig-image"><img src="https://static.wixstatic.com/media/c569b3_07c53dc6d5644e7dbd2dfc732ea52d1e~mv2.jpg/v1/fill/w_300,h_300/file.webp" alt="Gallery photo" loading="lazy" width="300" height="300" /></div>
        </div>
      </section>

      <jay:SiteFooter />
    </main>
  </body>
</html>
