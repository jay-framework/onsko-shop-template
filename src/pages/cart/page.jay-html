<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart | Onsko</title>
    <meta name="description" content="Review your cart and checkout at Onsko.">
    <script type="application/jay-headless"
            plugin="@jay-framework/wix-cart"
            contract="cart-page"
            key="cartPage"
    ></script>
    <script type="application/jay-headfull" src="../../components/site-header/site-header" names="SiteHeader" contract="../../components/site-header/site-header.jay-contract"></script>
    <script type="application/jay-headfull" src="../../components/site-footer/site-footer" names="SiteFooter" contract="../../components/site-footer/site-footer.jay-contract"></script>
    <script type="application/jay-data">
      data:
    </script>
    <link rel="stylesheet" href="../../styles/onsko-theme.css">
    <style>
        /* =====================================================
           ONSKO CART PAGE - CENTERED COLUMN + FLOATING SUMMARY
           ===================================================== */

        .cart-page {
            min-height: 100vh;
        }

        /* Cart Header Section */
        .cart-hero {
            text-align: center;
            padding: 120px var(--page-padding) 36px;
            border-bottom: 1px solid var(--border);
            background: var(--bg-secondary);
        }

        .cart-hero .page-title {
            margin-bottom: 8px;
        }

        .cart-hero .item-count {
            font-size: 15px;
            color: var(--text-secondary);
        }

        .cart-hero-actions {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-top: 20px;
        }

        /* Cart Content Area */
        .cart-content-area {
            max-width: 700px;
            margin: 0 auto;
            padding: 40px var(--page-padding);
        }

        /* Cart Items List */
        .cart-items {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .cart-item {
            display: grid;
            grid-template-columns: 100px 1fr;
            gap: 20px;
            padding: 20px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            transition: all var(--transition-base);
        }

        .cart-item:hover {
            box-shadow: var(--shadow-md);
            border-color: var(--border-hover);
        }

        .cart-item.removing {
            opacity: 0.4;
            pointer-events: none;
            transform: scale(0.98);
        }

        .cart-item.updating {
            opacity: 0.7;
        }

        .cart-item-image-link {
            display: block;
        }

        .cart-item-image {
            width: 100px;
            height: 120px;
            object-fit: cover;
            border-radius: var(--radius-md);
            background: var(--bg-product-image);
        }

        .cart-item-info {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .cart-item-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
        }

        .cart-item-name {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.3;
            transition: color var(--transition-fast);
        }

        .cart-item-name:hover {
            color: var(--accent);
        }

        .cart-item-price {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
        }

        .cart-item-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .cart-item-variant {
            font-size: 12px;
            color: var(--text-secondary);
            background: var(--bg-secondary);
            padding: 2px 8px;
            border-radius: var(--radius-sm);
        }

        .cart-item-sku {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .cart-item-discount {
            font-size: 12px;
            color: var(--success);
            font-weight: 600;
        }

        .cart-item-actions-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: auto;
            padding-top: 8px;
        }

        /* Cart Summary Bar */
        .floating-summary {
            position: static;
            z-index: auto;
            box-shadow: none;
            background: var(--bg-card);
            border-top: 1px solid var(--border);
        }

        .summary-bar-inner {
            max-width: 700px;
            margin: 0 auto;
            padding: 20px var(--page-padding);
        }

        .summary-main-row {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .summary-totals {
            flex: 1;
            display: flex;
            flex-wrap: wrap;
            gap: 24px;
        }

        .summary-item {
            display: flex;
            flex-direction: column;
        }

        .summary-item .label {
            font-size: 11px;
            margin-bottom: 2px;
        }

        .summary-item .value {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .summary-item.total .value {
            font-size: 22px;
            font-weight: 700;
            color: var(--accent);
        }

        .summary-item.discount .value {
            color: var(--success);
        }

        .summary-checkout {
            flex-shrink: 0;
        }

        .summary-checkout .btn {
            min-width: 160px;
        }

        /* Coupon Row */
        .coupon-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid var(--border);
        }

        .coupon-row .input {
            flex: 1;
            max-width: 180px;
            padding: 8px 12px;
            font-size: 13px;
        }

        .coupon-applied-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            background: var(--success-bg);
            border-radius: var(--radius-md);
            font-size: 13px;
            color: var(--success);
            font-weight: 600;
        }

        .coupon-remove {
            background: none;
            border: none;
            color: var(--success);
            cursor: pointer;
            font-size: 16px;
            opacity: 0.7;
            transition: opacity var(--transition-fast);
        }

        .coupon-remove:hover {
            opacity: 1;
        }

        .coupon-error-text {
            font-size: 12px;
            color: var(--error);
        }

        /* Empty Cart */
        .empty-cart-view {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 60vh;
            text-align: center;
            padding: 48px var(--page-padding);
        }

        .empty-icon {
            font-size: 80px;
            margin-bottom: 24px;
            opacity: 0.15;
        }

        .empty-title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        /* Loading State */
        .cart-loading-view {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 50vh;
            gap: 20px;
        }

        .loading-spinner-large {
            width: 48px;
            height: 48px;
            border: 3px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: cart-spin 0.7s linear infinite;
        }

        @keyframes cart-spin {
            to { transform: rotate(360deg); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .cart-item {
                grid-template-columns: 80px 1fr;
                gap: 12px;
                padding: 16px;
            }

            .cart-item-image {
                width: 80px;
                height: 100px;
            }

            .cart-item-header {
                flex-direction: column;
                gap: 4px;
            }

            .summary-main-row {
                flex-direction: column;
                gap: 16px;
            }

            .summary-totals {
                width: 100%;
                justify-content: space-between;
            }

            .summary-checkout {
                width: 100%;
            }

            .summary-checkout .btn {
                width: 100%;
            }

            .coupon-row {
                flex-wrap: wrap;
            }

            .coupon-row .input {
                max-width: none;
                flex: 1 1 auto;
            }
        }

        @media (max-width: 480px) {
            .cart-hero-actions {
                flex-direction: column;
            }

            .cart-hero-actions .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <main class="cart-page">
        <!-- Site Header -->
        <jay:SiteHeader />

        <!-- Cart Header -->
        <section class="cart-hero">
            <h1 class="page-title">your cart</h1>
            <p class="item-count" if="cartPage.summary.itemCount >= 0">{cartPage.summary.itemCount} items</p>
            <div class="cart-hero-actions">
                <a href="/products" ref="cartPage.continueShoppingLink" class="btn btn-ghost">
                    continue shopping
                </a>
                <button ref="cartPage.clearCartButton" class="btn btn-ghost">
                    clear cart
                </button>
            </div>
        </section>

        <!-- Loading State -->
        <div class="cart-loading-view" if="cartPage.isLoading">
            <div class="loading-spinner-large"></div>
            <p style="color: var(--text-secondary);">loading your cart...</p>
        </div>

        <!-- Empty State -->
        <div class="empty-cart-view" if="cartPage.isEmpty && !cartPage.isLoading">
            <div class="empty-icon">🛒</div>
            <h2 class="empty-title">your cart is empty</h2>
            <a href="/products" ref="cartPage.emptyCartLink" class="btn btn-primary btn-lg">
                start shopping
            </a>
        </div>

        <!-- Cart Items -->
        <div class="cart-content-area" if="!cartPage.isEmpty && !cartPage.isLoading">
            <div class="cart-items">
                <article class="cart-item {isUpdatingQuantity ? updating} {isRemoving ? removing}"
                         forEach="cartPage.lineItems"
                         trackBy="lineItemId">

                    <a href="{productUrl}" class="cart-item-image-link">
                        <img class="cart-item-image"
                             src="{image.url}/v1/fill/w_200,h_240/file.webp"
                             alt="{image.altText}"
                             loading="lazy"
                             width="200"
                             height="240"
                             fetchpriority="high">
                    </a>

                    <div class="cart-item-info">
                        <div class="cart-item-header">
                            <a href="{productUrl}" class="cart-item-name" ref="cartPage.lineItems.productLink">
                                {productName}
                            </a>
                            <span class="cart-item-price">{lineTotal.formattedAmount}</span>
                        </div>

                        <div class="cart-item-meta">
                            <span class="cart-item-variant" if="variantName">{variantName}</span>
                            <span class="cart-item-sku" if="sku">SKU: {sku}</span>
                        </div>

                        <span class="cart-item-discount" if="hasDiscount">
                            Save {lineDiscount.formattedAmount}
                        </span>

                        <div class="cart-item-actions-row">
                            <div class="qty-controls">
                                <button class="qty-btn" ref="cartPage.lineItems.decrementButton">&minus;</button>
                                <input type="number"
                                       class="qty-input"
                                       ref="cartPage.lineItems.quantity"
                                       value="{quantity}"
                                       min="1"
                                       max="99"
                                       aria-label="Quantity">
                                <button class="qty-btn" ref="cartPage.lineItems.incrementButton">+</button>
                            </div>
                            <button class="remove-btn" ref="cartPage.lineItems.removeButton">
                                remove
                            </button>
                        </div>
                    </div>
                </article>
            </div>
        </div>

        <!-- Floating Summary Bar -->
        <div class="floating-summary" if="!cartPage.isEmpty && !cartPage.isLoading">
            <div class="summary-bar-inner">
                <div class="summary-main-row">
                    <div class="summary-totals">
                        <div class="summary-item">
                            <span class="label">subtotal</span>
                            <span class="value">{cartPage.summary.subtotal.formattedAmount}</span>
                        </div>
                        <div class="summary-item discount" if="cartPage.summary.hasDiscount">
                            <span class="label">discount</span>
                            <span class="value">-{cartPage.summary.discount.formattedAmount}</span>
                        </div>
                        <div class="summary-item" if="cartPage.summary.showTax">
                            <span class="label">est. tax</span>
                            <span class="value">{cartPage.summary.estimatedTax.formattedAmount}</span>
                        </div>
                        <div class="summary-item total">
                            <span class="label">total</span>
                            <span class="value">{cartPage.summary.estimatedTotal.formattedAmount}</span>
                        </div>
                    </div>
                    <div class="summary-checkout">
                        <button class="btn btn-primary btn-lg" ref="cartPage.checkoutButton">
                            <span if="!cartPage.isCheckingOut">checkout</span>
                            <span if="cartPage.isCheckingOut">processing...</span>
                        </button>
                    </div>
                </div>

                <!-- Coupon Row -->
                <div class="coupon-row">
                    <div if="!cartPage.coupon.hasAppliedCoupon" style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                        <input type="text"
                               class="input"
                               ref="cartPage.coupon.code"
                               value="{cartPage.coupon.code}"
                               placeholder="promo code"
                               aria-label="Promo code">
                        <button class="btn btn-ghost btn-sm" ref="cartPage.coupon.applyButton">
                            apply
                        </button>
                        <span class="coupon-error-text" if="cartPage.coupon.hasError">{cartPage.coupon.errorMessage}</span>
                    </div>

                    <div class="coupon-applied-tag" if="cartPage.coupon.hasAppliedCoupon">
                        ✓ {cartPage.coupon.appliedCode}
                        <button class="coupon-remove" ref="cartPage.coupon.removeButton">×</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- Site Footer -->
        <jay:SiteFooter />
    </main>
</body>
</html>
