<html>
  <head>
    <script type="application/jay-headless"
            plugin="@jay-framework/wix-stores"
            contract="product-search"
            key="productSearch"
    ></script>
    <title>{productSearch.categoryHeader.name} | Onsko</title>
    <meta name="description" content="{productSearch.categoryHeader.description}">
    <script type="application/jay-headfull" src="../../../components/site-header/site-header" names="SiteHeader" contract="../../../components/site-header/site-header.jay-contract"></script>
    <script type="application/jay-headfull" src="../../../components/site-footer/site-footer" names="SiteFooter" contract="../../../components/site-footer/site-footer.jay-contract"></script>
    <script type="application/jay-data">
      data:
    </script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,200;0,400;0,600;0,700;1,400;1,700&display=swap">
    <link rel="stylesheet" href="../../../styles/onsko-theme.css" />
    <style>
      /* =====================================================
         ONSKO PRODUCTS PAGE - SIDEBAR + GRID (DESKTOP)
         FILTER POPOVER (MOBILE < 1000px)
         ===================================================== */

      .shop-page {
        min-height: 100vh;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px; /* design-system: allow */
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* Shop Layout — sidebar left + grid right on desktop */
      .shop-layout {
        padding: 170px var(--page-padding) 80px; /* design-system: allow */
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 48px;
      }

      /* Sidebar — visible on desktop */
      .shop-sidebar {
        position: sticky;
        top: 80px;
        align-self: start;
      }

      .sidebar-section {
        margin-bottom: 32px;
      }

      .sidebar-section-title {
        font-family: 'Poppins', sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: 0.01em;
        margin-bottom: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
      }

      /* Filter bar — hidden on desktop, shown on mobile */
      .filter-bar {
        display: none;
        justify-content: flex-end;
        align-items: center;
        padding-bottom: 24px;
      }

      .filter-toggle-btn {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 500;
        color: var(--text-primary);
        text-decoration: underline;
        text-underline-offset: 3px;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        transition: color var(--transition-fast);
      }

      .filter-toggle-btn:hover {
        color: var(--text-secondary);
      }

      /* ── Filter Popover (mobile only) ── */
      .filter-popover {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        margin: 0;
        padding: 0;
        border: none;
        background: var(--bg-primary, #f5f3ef);
        z-index: 200;
        opacity: 0;
        transform: translateX(100%);
        transition: opacity 0.3s ease, transform 0.3s ease, display 0.3s ease allow-discrete;
        overflow-y: auto;
      }

      .filter-popover:popover-open {
        opacity: 1;
        transform: translateX(0);
      }

      @starting-style {
        .filter-popover:popover-open {
          opacity: 0;
          transform: translateX(100%);
        }
      }

      .filter-popover-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px 32px;
        border-bottom: 1px solid var(--border);
      }

      .filter-popover-title {
        font-family: 'Poppins', sans-serif;
        font-size: 24px;
        font-weight: 600;
        color: var(--text-primary);
        letter-spacing: -0.01em;
      }

      .filter-popover-close {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        padding: 8px;
        cursor: pointer;
        color: var(--text-primary);
      }

      .filter-popover-close svg {
        width: 24px;
        height: 24px;
      }

      .filter-popover-body {
        padding: 32px;
      }

      .filter-section {
        margin-bottom: 36px;
      }

      .filter-section:last-child {
        margin-bottom: 0;
      }

      .filter-section-title {
        font-family: 'Poppins', sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: 0.01em;
        margin-bottom: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
      }

      /* Shared styles for category list & price filter */
      .category-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .category-list a {
        display: block;
        padding: 3px 0;
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        color: var(--text-secondary);
        text-decoration: none;
        transition: color var(--transition-fast);
      }

      .category-list a:hover {
        color: var(--text-primary);
      }

      .category-list a.active {
        color: var(--text-primary);
        text-decoration: underline;
      }

      /* Price slider */
      .price-filter-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 0;
        padding-bottom: 8px;
        margin-bottom: 16px;
      }

      .price-filter-label {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        color: var(--text-primary);
      }

      .price-filter-details {
        border: none;
      }

      .price-filter-details summary {
        list-style: none;
        cursor: pointer;
      }

      .price-filter-details summary::-webkit-details-marker {
        display: none;
      }

      .price-filter-toggle {
        font-size: 20px;
        color: var(--text-secondary);
        line-height: 1;
      }

      .price-filter-details[open] .price-filter-toggle::before {
        content: '−';
      }

      .price-filter-details:not([open]) .price-filter-toggle::before {
        content: '+';
      }

      .price-slider-track {
        position: relative;
        height: 36px;
        display: flex;
        align-items: center;
      }

      .price-slider-track::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--text-primary);
      }

      .price-slider-track input[type="range"] {
        position: absolute;
        left: 0;
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
        background: transparent;
        pointer-events: none;
        margin: 0;
        padding: 0;
        height: 36px;
        z-index: 1;
      }

      .price-slider-track input[type="range"]::-webkit-slider-runnable-track {
        height: 2px;
        background: transparent;
      }

      .price-slider-track input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 18px;
        height: 18px;
        background: var(--text-primary);
        border-radius: 50%;
        cursor: pointer;
        pointer-events: auto;
        margin-top: -8px;
        position: relative;
        z-index: 2;
      }

      .price-slider-track input[type="range"]::-moz-range-track {
        height: 2px;
        background: transparent;
        border: none;
      }

      .price-slider-track input[type="range"]::-moz-range-thumb {
        width: 18px;
        height: 18px;
        background: var(--text-primary);
        border-radius: 50%;
        border: none;
        cursor: pointer;
        pointer-events: auto;
      }

      .price-slider-values {
        display: flex;
        justify-content: space-between;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        color: var(--text-secondary);
        margin-top: 2px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
      }

      /* Results Area */
      .shop-results {
        min-width: 0;
      }

      /* 3-column product grid */
      .products-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      /* Product card — clean style, no background */
      .products-grid .product-card {
        display: flex;
        flex-direction: column;
        height: auto;
        background: none;
        border-radius: 0; /* design-system: allow */
        overflow: visible;
        box-shadow: none;
      }

      .products-grid .product-card:hover {
        transform: none;
        box-shadow: none;
      }

      .products-grid .product-card .product-card-image {
        aspect-ratio: 2 / 3;
        border-radius: 20px;
        overflow: hidden;
      }

      .products-grid .product-card .ribbon {
        background: #bdd8f1;
        color: var(--text-primary);
        font-family: poppins-extralight, poppins, sans-serif;
        font-size: 12px;
        font-weight: 400;
        padding: 3px 10px;
        border-radius: 2px;
        letter-spacing: 0.02em;
      }

      .products-grid .product-card-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 12px 0 0;
      }

      .products-grid .product-card-price {
        margin-top: 0;
      }

      /* Pagination */
      .load-more-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        margin-top: 48px;
        padding-top: 32px;
        border-top: 1px solid var(--border-light);
      }

      .load-more-info {
        font-size: 13px;
        color: var(--text-muted);
      }

      /* Loading overlay */
      .loading-overlay {
        position: fixed;
        inset: 0;
        background: rgba(249, 245, 240, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
      }

      /* ── Below 1000px: hide sidebar, show filter link + popover ── */
      @media (max-width: 1000px) {
        .shop-layout {
          grid-template-columns: 1fr;
          padding-top: 120px; /* design-system: allow */
          gap: 0;
        }

        .shop-sidebar {
          display: none;
        }

        .filter-bar {
          display: flex;
        }

        .products-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 600px) {
        .products-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main class="shop-page">
      <!-- Site Header -->
      <jay:SiteHeader />

      <!-- Loading Overlay -->
      <div class="loading-overlay" if="productSearch.isSearching">
        <div class="loading-spinner"></div>
      </div>

      <!-- Filter Popover -->
      <div id="shop-filter-popover" popover class="filter-popover">
        <div class="filter-popover-header">
          <span class="filter-popover-title">Filter</span>
          <button popovertarget="shop-filter-popover" popovertargetaction="hide" class="filter-popover-close" aria-label="Close filters">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
          </button>
        </div>
        <div class="filter-popover-body">
          <!-- Browse by Category -->
          <div class="filter-section">
            <h2 class="filter-section-title">browse by</h2>
            <div class="category-list">
              <a href="/products">all products</a>
              <a href="{categoryUrl}" class="{isSelected ? active}" forEach="productSearch.filters.categoryFilter.categories" trackBy="categoryId">
                {categoryName}
              </a>
            </div>
          </div>

          <!-- Filter by Price -->
          <div class="filter-section">
            <h2 class="filter-section-title">filter by</h2>
            <details class="price-filter-details" open>
              <summary class="price-filter-header">
                <span class="price-filter-label">Price</span>
                <span class="price-filter-toggle"></span>
              </summary>
              <div class="price-slider-track">
                <input
                  type="range"
                  min="{productSearch.filters.priceRange.minBound}"
                  max="{productSearch.filters.priceRange.maxBound}"
                  value="{productSearch.filters.priceRange.minPrice}"
                  ref="productSearch.filters.priceRange.minPrice"
                  aria-label="Minimum price"
                />
                <input
                  type="range"
                  min="{productSearch.filters.priceRange.minBound}"
                  max="{productSearch.filters.priceRange.maxBound}"
                  value="{productSearch.filters.priceRange.maxPrice}"
                  ref="productSearch.filters.priceRange.maxPrice"
                  aria-label="Maximum price"
                />
              </div>
              <div class="price-slider-values">
                <span>${productSearch.filters.priceRange.minPrice}</span>
                <span>${productSearch.filters.priceRange.maxPrice}</span>
              </div>
            </details>
          </div>
        </div>
      </div>

      <!-- Page heading (visually hidden, for SEO) -->
      <h1 class="sr-only">{productSearch.categoryHeader.name}</h1>

      <!-- Main Shop Layout -->
      <div class="shop-layout">
        <!-- Sidebar (desktop) -->
        <aside class="shop-sidebar" aria-label="Product filters">
          <!-- Browse by Category -->
          <div class="sidebar-section">
            <h2 class="sidebar-section-title">browse by</h2>
            <div class="category-list">
              <a href="/products">all products</a>
              <a href="{categoryUrl}" class="{isSelected ? active}" forEach="productSearch.filters.categoryFilter.categories" trackBy="categoryId">
                {categoryName}
              </a>
            </div>
          </div>

          <!-- Filter by Price -->
          <div class="sidebar-section">
            <h2 class="sidebar-section-title">filter by</h2>
            <details class="price-filter-details" open>
              <summary class="price-filter-header">
                <span class="price-filter-label">Price</span>
                <span class="price-filter-toggle"></span>
              </summary>
              <div class="price-slider-track">
                <input
                  type="range"
                  min="{productSearch.filters.priceRange.minBound}"
                  max="{productSearch.filters.priceRange.maxBound}"
                  value="{productSearch.filters.priceRange.minPrice}"
                  ref="productSearch.filters.priceRange.minPrice"
                  aria-label="Minimum price"
                />
                <input
                  type="range"
                  min="{productSearch.filters.priceRange.minBound}"
                  max="{productSearch.filters.priceRange.maxBound}"
                  value="{productSearch.filters.priceRange.maxPrice}"
                  ref="productSearch.filters.priceRange.maxPrice"
                  aria-label="Maximum price"
                />
              </div>
              <div class="price-slider-values">
                <span>${productSearch.filters.priceRange.minPrice}</span>
                <span>${productSearch.filters.priceRange.maxPrice}</span>
              </div>
            </details>
          </div>
        </aside>

        <!-- Filter Bar (mobile) -->
        <div class="filter-bar">
          <button class="filter-toggle-btn" popovertarget="shop-filter-popover" aria-label="Open filters">Filter</button>
        </div>

        <!-- Results -->
        <section class="shop-results">
          <!-- Empty State -->
          <div class="empty-state" if="!productSearch.hasResults">
            <div class="empty-state-icon">✻</div>
            <h2 class="empty-state-title">no products found</h2>
            <p class="empty-state-message">{productSearch.emptyStateMessage}</p>
          </div>

          <!-- Product Grid -->
          <div class="products-grid" if="productSearch.hasResults">
            <article class="product-card {isAddingToCart ? is-adding}" forEach="productSearch.searchResults" trackBy="_id" jay-design="allow">
              <a href="{productUrl}" class="product-card-image">
                <img
                  src="{thumbnail.url}/v1/fill/w_600,h_600/file.webp"
                  srcset="{thumbnail.url}/v1/fill/w_300%2Ch_300/file.webp 300w, {thumbnail.url}/v1/fill/w_400%2Ch_400/file.webp 400w, {thumbnail.url}/v1/fill/w_600%2Ch_600/file.webp 600w"
                  sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 25vw"
                  alt="{thumbnail.altText}"
                  loading="lazy"
                  width="600"
                  height="600"
                  fetchpriority="high"
                />
                <!-- Ribbon Badge -->
                <span class="badge badge-accent ribbon" if="hasRibbon">{ribbon.name}</span>
              </a>
              <div class="product-card-content">
                <h2 class="product-card-name">
                  <a href="{productUrl}" ref="productSearch.searchResults.productLink">{name}</a>
                </h2>
                <div class="product-card-price">
                  <span class="current-price">{price}</span>
                  <span class="original-price" if="hasDiscount">{strikethroughPrice}</span>
                  <span class="badge badge-error" if="hasDiscount" jay-design="allow">sale</span>
                </div>
              </div>
            </article>
          </div>

          <!-- Load More -->
          <div class="load-more-section" if="productSearch.hasResults">
            <span class="load-more-info">
              {productSearch.loadedCount} of {productSearch.totalCount} products
            </span>
            <button
              class="btn btn-secondary"
              ref="productSearch.loadMoreButton"
              if="productSearch.hasMore && !productSearch.isSearching"
            >
              load more
            </button>
            <span class="load-more-info" if="!productSearch.hasMore && productSearch.totalCount > 0">
              all products shown
            </span>
          </div>
        </section>
      </div>

      <!-- Site Footer -->
      <jay:SiteFooter />
    </main>
  </body>
</html>
