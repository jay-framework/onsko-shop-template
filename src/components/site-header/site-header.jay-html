<html>
  <head>
    <script type="application/jay-headless"
            plugin="@jay-framework/wix-cart"
            contract="cart-indicator"
    ></script>
    <script type="application/jay-headless"
            plugin="@jay-framework/wix-members"
            contract="login-indicator"
    ></script>
    <script type="application/jay-data">
      data:
    </script>
  </head>
  <body>
    <header class="site-header {headerHidden ? header-hidden}">
      <div class="site-header-bar">
        <div class="site-header-inner">
          <a href="/" class="site-logo"><span class="site-logo-icon"><svg preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 19.009 19" height="19" width="19" role="presentation" aria-hidden="true"><path fill="currentColor" d="M16.392 9.5A2.626 2.626 0 0 0 19 6.875a2.63 2.63 0 0 0-2.624-2.626c-.723 0-1.412.149-2.04.413a5.2 5.2 0 0 0 .413-2.04A2.62 2.62 0 0 0 12.124.003 2.62 2.62 0 0 0 9.5 2.607 2.626 2.626 0 0 0 6.876 0 2.63 2.63 0 0 0 4.25 2.625c0 .723.147 1.413.413 2.04a5.25 5.25 0 0 0-2.04-.413A2.623 2.623 0 0 0 .002 6.877a2.62 2.62 0 0 0 2.606 2.624A2.626 2.626 0 0 0 0 12.126a2.627 2.627 0 0 0 2.624 2.624 5.2 5.2 0 0 0 2.04-.413 5.2 5.2 0 0 0-.413 2.04 2.62 2.62 0 0 0 2.625 2.621A2.62 2.62 0 0 0 9.5 16.393 2.626 2.626 0 0 0 12.124 19a2.63 2.63 0 0 0 2.625-2.625c0-.723-.147-1.412-.413-2.04a5.2 5.2 0 0 0 2.04.413 2.624 2.624 0 0 0 .016-5.249m-6.895 1.626c-.723 0-1.414.148-2.04.413a5.2 5.2 0 0 0 .413-2.04 5.2 5.2 0 0 0-.413-2.04 5.2 5.2 0 0 0 2.04.413 5.2 5.2 0 0 0 2.04-.412 5.2 5.2 0 0 0-.413 2.04c0 .722.147 1.412.413 2.039a5.25 5.25 0 0 0-2.04-.413"/></svg></span> onsko</a>
          <nav class="site-nav">
            <a href="/">home</a>
            <a href="/products">shop</a>
            <a href="/#our-story">about</a>
          </nav>
          <div class="site-header-actions">
            <jay:login-indicator>
              <button if="!isLoggedIn" ref="loginButton" class="site-header-action-text site-login-btn">log in</button>
              <span if="isLoggedIn" class="site-header-action-text">{memberName}</span>
              <button if="isLoggedIn" ref="logoutButton" class="site-header-action-text site-login-btn">log out</button>
            </jay:login-indicator>
            <jay:cart-indicator>
              <a href="/cart"
                 class="site-cart-indicator {hasItems ? has-items} {isLoading ? is-loading} {justAdded ? just-added}"
                 ref="cartLink">
                <span class="site-cart-badge">{itemCount}</span>
              </a>
            </jay:cart-indicator>
            <button class="site-hamburger-btn" popovertarget="site-mobile-menu" aria-label="Open menu">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </div>
      </div>
    </header>

    <div id="site-mobile-menu" popover class="site-mobile-menu">
      <div class="site-mobile-menu-header">
        <a href="/" class="site-mobile-menu-logo"><svg preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 19.009 19" height="19" width="19" role="presentation" aria-hidden="true"><path fill="currentColor" d="M16.392 9.5A2.626 2.626 0 0 0 19 6.875a2.63 2.63 0 0 0-2.624-2.626c-.723 0-1.412.149-2.04.413a5.2 5.2 0 0 0 .413-2.04A2.62 2.62 0 0 0 12.124.003 2.62 2.62 0 0 0 9.5 2.607 2.626 2.626 0 0 0 6.876 0 2.63 2.63 0 0 0 4.25 2.625c0 .723.147 1.413.413 2.04a5.25 5.25 0 0 0-2.04-.413A2.623 2.623 0 0 0 .002 6.877a2.62 2.62 0 0 0 2.606 2.624A2.626 2.626 0 0 0 0 12.126a2.627 2.627 0 0 0 2.624 2.624 5.2 5.2 0 0 0 2.04-.413 5.2 5.2 0 0 0-.413 2.04 2.62 2.62 0 0 0 2.625 2.621A2.62 2.62 0 0 0 9.5 16.393 2.626 2.626 0 0 0 12.124 19a2.63 2.63 0 0 0 2.625-2.625c0-.723-.147-1.412-.413-2.04a5.2 5.2 0 0 0 2.04.413 2.624 2.624 0 0 0 .016-5.249m-6.895 1.626c-.723 0-1.414.148-2.04.413a5.2 5.2 0 0 0 .413-2.04 5.2 5.2 0 0 0-.413-2.04 5.2 5.2 0 0 0 2.04.413 5.2 5.2 0 0 0 2.04-.412 5.2 5.2 0 0 0-.413 2.04c0 .722.147 1.412.413 2.039a5.25 5.25 0 0 0-2.04-.413"/></svg> onsko</a>
        <button popovertarget="site-mobile-menu" popovertargetaction="hide" class="site-mobile-menu-close" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
        </button>
      </div>
      <nav class="site-mobile-menu-nav">
        <a href="/">home</a>
        <a href="/products">shop</a>
        <a href="/#our-story">about</a>
      </nav>
      <div class="site-mobile-menu-login">
        <jay:login-indicator>
          <button if="!isLoggedIn" ref="loginButton" class="site-mobile-login-btn" popovertarget="site-mobile-menu" popovertargetaction="hide">log in</button>
          <span if="isLoggedIn">{memberName}</span>
          <button if="isLoggedIn" ref="logoutButton" class="site-mobile-login-btn" popovertarget="site-mobile-menu" popovertargetaction="hide">log out</button>
        </jay:login-indicator>
      </div>
    </div>
  </body>
</html>
